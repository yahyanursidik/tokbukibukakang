<script>
  import { getSupabaseBrowserClient } from '@/lib/supabase/client';

  const formatFileSize = (size: number) => {
    if (size >= 1024 * 1024) {
      return `${(size / 1024 / 1024).toFixed(1)} MB`;
    }

    if (size >= 1024) {
      return `${Math.round(size / 1024)} KB`;
    }

    return `${size} B`;
  };

  const normalizeSlug = (value: string) =>
    value
      .trim()
      .normalize('NFKD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');

  const setupAutoSlug = (form: HTMLFormElement) => {
    const titleInput = form.querySelector<HTMLInputElement>('[data-auto-slug-title]');
    const slugInput = form.querySelector<HTMLInputElement>('[data-auto-slug-input]');

    if (!titleInput || !slugInput) {
      return;
    }

    const syncSlug = () => {
      slugInput.value = normalizeSlug(titleInput.value);
    };

    if (!slugInput.value) {
      syncSlug();
    }

    titleInput.addEventListener('input', syncSlug);
  };

  const setProgress = (form: HTMLFormElement, value: number, message: string) => {
    const feedback = form.querySelector<HTMLElement>('[data-submit-feedback]');
    const bar = form.querySelector<HTMLElement>('[data-submit-progress]');
    const percent = form.querySelector<HTMLElement>('[data-submit-percent]');
    const text = form.querySelector<HTMLElement>('[data-submit-message]');
    const safeValue = Math.max(0, Math.min(100, Math.round(value)));

    feedback?.classList.remove('hidden');
    if (bar) {
      bar.style.width = `${safeValue}%`;
    }
    if (percent) {
      percent.textContent = `${safeValue}%`;
    }
    if (text) {
      text.textContent = message;
    }
  };

  const restoreForm = (form: HTMLFormElement, message: string) => {
    form.dataset.submitting = 'false';
    form.querySelectorAll<HTMLButtonElement>('button[type="submit"]').forEach((button) => {
      button.disabled = false;
      button.classList.remove('cursor-wait', 'opacity-75');
      button.textContent = button.dataset.defaultLabel ?? button.textContent ?? 'Simpan';
    });
    setProgress(form, 0, message);
  };

  const getFormSlug = (form: HTMLFormElement) => {
    const slugInput = form.querySelector<HTMLInputElement>('[data-auto-slug-input]');
    const titleInput = form.querySelector<HTMLInputElement>('[data-auto-slug-title]');

    return normalizeSlug(slugInput?.value || titleInput?.value || 'upload');
  };

  const appendUrlToTarget = (form: HTMLFormElement, targetName: string, mode: string, url: string) => {
    const target = form.elements.namedItem(targetName);

    if (!(target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement)) {
      throw new Error(`Target URL upload "${targetName}" tidak ditemukan.`);
    }

    if (mode === 'append-lines') {
      const existingLines = target.value
        .split('\n')
        .map((line) => line.trim())
        .filter(Boolean);
      target.value = [...existingLines, url].join('\n');
      return;
    }

    target.value = url;
  };

  const requestSignedUpload = async (input: HTMLInputElement, file: File, form: HTMLFormElement) => {
    const response = await fetch('/admin/api/storage-upload-url', {
      method: 'POST',
      headers: {
        'content-type': 'application/json'
      },
      body: JSON.stringify({
        bucket: input.dataset.directUploadBucket,
        fieldName: input.dataset.directUploadField ?? input.name,
        slug: getFormSlug(form),
        fileName: file.name,
        contentType: file.type,
        size: file.size
      })
    });

    const payload = (await response.json().catch(() => null)) as
      | {
          bucket?: string;
          path?: string;
          token?: string;
          publicUrl?: string;
          message?: string;
        }
      | null;

    if (!response.ok || !payload?.bucket || !payload.path || !payload.token || !payload.publicUrl) {
      throw new Error(payload?.message ?? 'URL upload Supabase gagal dibuat.');
    }

    return {
      bucket: payload.bucket,
      path: payload.path,
      token: payload.token,
      publicUrl: payload.publicUrl
    };
  };

  const uploadDirectFiles = async (form: HTMLFormElement) => {
    const inputs = Array.from(form.querySelectorAll<HTMLInputElement>('input[type="file"][data-direct-upload-bucket]'));
    const uploadItems = inputs.flatMap((input) =>
      Array.from(input.files ?? []).map((file) => ({
        input,
        file
      }))
    );

    if (uploadItems.length === 0) {
      return false;
    }

    const supabase = getSupabaseBrowserClient();
    let completed = 0;

    for (const { input, file } of uploadItems) {
      const targetName = input.dataset.directUploadTarget;
      const mode = input.dataset.directUploadMode ?? 'replace';

      if (!targetName) {
        throw new Error('Target URL upload belum dikonfigurasi.');
      }

      const startPercent = 8 + Math.round((completed / uploadItems.length) * 72);
      setProgress(form, startPercent, `Meng-upload ${completed + 1}/${uploadItems.length}: ${file.name}`);

      const signedUpload = await requestSignedUpload(input, file, form);
      const { error } = await supabase.storage.from(signedUpload.bucket).uploadToSignedUrl(
        signedUpload.path,
        signedUpload.token,
        file,
        {
          contentType: file.type
        }
      );

      if (error) {
        throw new Error(`Upload ${file.name} gagal: ${error.message}`);
      }

      appendUrlToTarget(form, targetName, mode, signedUpload.publicUrl);
      completed += 1;
      setProgress(form, 8 + Math.round((completed / uploadItems.length) * 72), `Upload ${completed}/${uploadItems.length} selesai.`);
    }

    inputs.forEach((input) => {
      input.value = '';
      const field = input.closest('[data-upload-field]');
      const previewStatus = field?.querySelector<HTMLElement>('[data-upload-preview-status]');
      if (previewStatus) {
        previewStatus.textContent = 'File sudah di-upload ke Supabase. URL gambar akan ikut disimpan.';
      }
    });

    return true;
  };

  const renderPreview = (input: HTMLInputElement) => {
    const field = input.closest('[data-upload-field]');
    const preview = field?.querySelector<HTMLElement>('[data-upload-preview]');
    const previewList = field?.querySelector<HTMLElement>('[data-upload-preview-list]');
    const previewStatus = field?.querySelector<HTMLElement>('[data-upload-preview-status]');

    if (!preview || !previewList || !previewStatus) {
      return;
    }

    const files = Array.from(input.files ?? []);
    previewList.innerHTML = '';

    if (files.length === 0) {
      preview.classList.add('hidden');
      previewStatus.textContent = 'Belum ada file dipilih.';
      return;
    }

    preview.classList.remove('hidden');
    previewStatus.textContent = `${files.length} file siap di-upload. Progress akan tampil saat tombol simpan ditekan.`;

    files.forEach((file) => {
      const item = document.createElement('div');
      item.className = 'grid gap-2 rounded-2xl border border-[#eadcc7] bg-white/80 p-3';

      const image = document.createElement('img');
      image.className = 'aspect-[3/4] w-full rounded-2xl bg-parchment object-contain p-2';
      image.alt = `Pratinjau ${file.name}`;
      image.src = URL.createObjectURL(file);
      image.onload = () => URL.revokeObjectURL(image.src);

      const caption = document.createElement('p');
      caption.className = 'break-words text-xs font-semibold leading-5 text-[#70675e]';
      caption.textContent = `${file.name} - ${formatFileSize(file.size)}`;

      item.append(image, caption);
      previewList.append(item);
    });
  };

  document.querySelectorAll<HTMLInputElement>('[data-upload-input]').forEach((input) => {
    input.addEventListener('change', () => renderPreview(input));
  });

  document.querySelectorAll<HTMLFormElement>('[data-admin-feedback-form]').forEach((form) => {
    setupAutoSlug(form);

    form.addEventListener('submit', async (event) => {
      const submitEvent = event as SubmitEvent;
      const submitter = submitEvent.submitter instanceof HTMLButtonElement ? submitEvent.submitter : null;

      if (form.dataset.submitting === 'true') {
        event.preventDefault();
        return;
      }

      if (form.method.toLowerCase() !== 'post') {
        return;
      }

      event.preventDefault();
      form.dataset.submitting = 'true';

      form.querySelectorAll<HTMLButtonElement>('button[type="submit"]').forEach((button) => {
        button.dataset.defaultLabel = button.dataset.defaultLabel ?? button.textContent?.trim() ?? 'Simpan';
        button.disabled = true;
        button.classList.add('cursor-wait', 'opacity-75');
      });

      if (submitter) {
        submitter.textContent = submitter.dataset.loadingLabel ?? 'Menyimpan...';
      }

      const hasFiles = Array.from(form.querySelectorAll<HTMLInputElement>('input[type="file"]')).some((input) =>
        Array.from(input.files ?? []).some((file) => file.size > 0)
      );
      const startMessage = hasFiles ? 'Menyiapkan file dan data form...' : 'Mengirim data form...';
      setProgress(form, 5, startMessage);

      try {
        const hadDirectUploads = await uploadDirectFiles(form);
        if (hadDirectUploads) {
          setProgress(form, 84, 'URL gambar siap. Menyimpan data buku...');
        }
      } catch (error) {
        restoreForm(form, error instanceof Error ? error.message : 'Upload gambar belum berhasil.');
        return;
      }

      const xhr = new XMLHttpRequest();
      xhr.open(form.method, form.action || window.location.href);
      xhr.responseType = 'text';

      xhr.upload.addEventListener('progress', (progressEvent) => {
        if (!progressEvent.lengthComputable) {
          setProgress(form, 45, hasFiles ? 'Upload sedang berjalan...' : 'Data sedang dikirim...');
          return;
        }

        const uploadPercent = Math.round((progressEvent.loaded / progressEvent.total) * 90);
        setProgress(
          form,
          Math.max(10, uploadPercent),
          hasFiles ? 'Meng-upload file ke server...' : 'Mengirim data ke server...'
        );
      });

      xhr.upload.addEventListener('load', () => {
        setProgress(form, hasFiles ? 92 : 80, hasFiles ? 'Upload diterima, menyimpan ke Supabase...' : 'Menyimpan ke Supabase...');
      });

      xhr.addEventListener('load', () => {
        if (xhr.status >= 200 && xhr.status < 400) {
          setProgress(form, 100, 'Tersimpan. Memuat ulang tampilan...');
          const responseUrl = xhr.responseURL || window.location.href;
          document.open();
          document.write(xhr.responseText);
          document.close();
          window.history.replaceState(null, '', responseUrl);
          return;
        }

        if (xhr.status === 413) {
          restoreForm(form, 'Gagal menyimpan karena ukuran request terlalu besar. Coba pilih ulang gambar, lalu simpan lagi agar upload langsung ke Supabase berjalan.');
          return;
        }

        restoreForm(form, `Gagal menyimpan. Server mengembalikan status ${xhr.status}.`);
      });

      xhr.addEventListener('error', () => {
        restoreForm(form, 'Koneksi terputus saat menyimpan. Coba ulangi lagi.');
      });

      xhr.addEventListener('abort', () => {
        restoreForm(form, 'Proses simpan dibatalkan.');
      });

      setProgress(form, hasFiles ? 88 : 20, hasFiles ? 'Mengirim data tanpa file besar...' : 'Simpan dimulai...');
      xhr.send(new FormData(form));
    });
  });
</script>
