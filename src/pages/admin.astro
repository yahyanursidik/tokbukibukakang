---
import AdminShell from '@/components/AdminShell.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  clearAdminSessionCookie,
  isAdminAuthConfigured,
  isAdminAuthenticated,
  setAdminSessionCookie,
  verifySupabaseAdminLogin
} from '@/lib/admin/auth';
import { formatDateTime, formatRupiah, getAdminOverview, statusLabel } from '@/lib/admin/orders';

export const prerender = false;

let loginError = '';
let dashboardError = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = String(formData.get('_action') ?? '');

  if (action === 'logout') {
    clearAdminSessionCookie(Astro.cookies);
    return Astro.redirect('/admin');
  }

  if (!isAdminAuthConfigured()) {
    loginError = 'PUBLIC_SUPABASE_URL dan PUBLIC_SUPABASE_ANON_KEY belum dikonfigurasi.';
  } else {
    try {
      const session = await verifySupabaseAdminLogin(
        String(formData.get('email') ?? ''),
        String(formData.get('password') ?? '')
      );
      setAdminSessionCookie(Astro.cookies, session);
      return Astro.redirect(
        String(formData.get('next') ?? '/admin').startsWith('/admin')
          ? String(formData.get('next') ?? '/admin')
          : '/admin'
      );
    } catch (error) {
      loginError = error instanceof Error ? error.message : 'Login Ibu Kakang belum berhasil.';
    }
  }

}

const isAuthenticated = await isAdminAuthenticated(Astro.cookies);
const nextPath = Astro.url.searchParams.get('next') ?? '/admin';
let overview:
  | Awaited<ReturnType<typeof getAdminOverview>>
  | null = null;

if (isAuthenticated) {
  try {
    overview = await getAdminOverview();
  } catch (error) {
    dashboardError = error instanceof Error ? error.message : 'Dashboard belum dapat dimuat.';
  }
}
---

{
  !isAuthenticated ? (
    <BaseLayout title="Login Ibu Kakang" description="Login Ibu Kakang untuk Books by Ibunya Kakang">
      <section class="page-shell grid min-h-[68vh] place-items-center py-10">
        <form class="soft-card w-full max-w-md p-6 sm:p-8" method="post">
          <img class="mx-auto h-20 w-20 rounded-3xl bg-[#fffaf1] object-contain p-2 shadow-soft" src="/brand/ibu-kakang-logo.png" alt="" />
          <h1 class="mt-5 text-center font-serif text-3xl font-bold text-ink">Ibu Kakang</h1>
          <p class="mt-2 text-center text-sm text-[#70675e]">Masuk dengan akun Supabase yang sudah terdaftar untuk mengelola toko.</p>
          {loginError && (
            <p class="mt-5 rounded-3xl border border-date/25 bg-parchment/80 p-4 text-sm font-bold text-date">{loginError}</p>
          )}
          <input type="hidden" name="next" value={nextPath} />
          <label class="mt-6 grid gap-2 text-sm font-bold text-[#5f564e]">
            Email Ibu Kakang
            <input class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name="email" type="email" autocomplete="email" required />
          </label>
          <label class="mt-4 grid gap-2 text-sm font-bold text-[#5f564e]">
            Password Supabase
            <input class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name="password" type="password" autocomplete="current-password" required />
          </label>
          <button class="mt-5 w-full rounded-full bg-ink px-6 py-3 text-sm font-bold text-cream transition hover:-translate-y-0.5 hover:bg-date" type="submit">
            Masuk dashboard
          </button>
        </form>
      </section>
    </BaseLayout>
  ) : (
    <AdminShell title="Dashboard Ibu Kakang" currentPath={Astro.url.pathname}>
      <div class="watercolor-panel p-6 sm:p-8">
        <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Dashboard Ibu Kakang</p>
        <h1 class="mt-3 font-serif text-4xl font-bold text-ink">Ringkasan transaksi</h1>
        <p class="mt-3 max-w-2xl text-[#70675e]">Pantau order, pembayaran yang menunggu transfer, dan konfirmasi yang perlu diverifikasi.</p>
      </div>

      {dashboardError ? (
        <div class="mt-6 rounded-3xl border border-date/25 bg-parchment/80 p-5 text-sm font-bold text-date">{dashboardError}</div>
      ) : overview && (
        <>
          <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <article class="soft-card p-5">
              <p class="text-sm font-bold text-[#70675e]">Total orders</p>
              <p class="mt-2 font-serif text-4xl font-bold text-ink">{overview.totalOrders}</p>
            </article>
            <article class="soft-card p-5">
              <p class="text-sm font-bold text-[#70675e]">Waiting payment</p>
              <p class="mt-2 font-serif text-4xl font-bold text-date">{overview.waitingPayment}</p>
            </article>
            <article class="soft-card p-5">
              <p class="text-sm font-bold text-[#70675e]">Waiting verification</p>
              <p class="mt-2 font-serif text-4xl font-bold text-date">{overview.waitingVerification}</p>
            </article>
            <article class="soft-card p-5">
              <p class="text-sm font-bold text-[#70675e]">Confirmed payments</p>
              <p class="mt-2 font-serif text-4xl font-bold text-[#36543c]">{overview.confirmedPayments}</p>
            </article>
          </section>

          <section class="soft-card mt-6 overflow-hidden">
            <div class="flex flex-wrap items-center justify-between gap-3 border-b border-[#eadcc7] p-5">
              <h2 class="font-serif text-2xl font-bold text-ink">Recent orders</h2>
              <a class="rounded-full bg-ink px-4 py-2 text-sm font-bold text-cream" href="/admin/orders">Lihat semua</a>
            </div>
            <div class="overflow-x-auto">
              <table class="min-w-full text-left text-sm">
                <thead class="bg-parchment/70 text-xs uppercase tracking-[0.12em] text-date">
                  <tr>
                    <th class="px-5 py-3">Invoice</th>
                    <th class="px-5 py-3">Customer</th>
                    <th class="px-5 py-3">Payment</th>
                    <th class="px-5 py-3">Order</th>
                    <th class="px-5 py-3 text-right">Total</th>
                  </tr>
                </thead>
                <tbody>
                  {overview.recentOrders.map((order) => (
                    <tr class="border-t border-[#eadcc7]">
                      <td class="px-5 py-4 font-bold text-ink"><a href={`/admin/orders/${order.id}`}>{order.order_number}</a></td>
                      <td class="px-5 py-4 text-[#70675e]">{order.customer_name}<br /><span class="text-xs">{formatDateTime(order.created_at)}</span></td>
                      <td class="px-5 py-4"><span class="rounded-full bg-honey px-3 py-1 text-xs font-bold text-date">{statusLabel(order.payment_status)}</span></td>
                      <td class="px-5 py-4"><span class="rounded-full bg-parchment px-3 py-1 text-xs font-bold text-ink">{statusLabel(order.status)}</span></td>
                      <td class="px-5 py-4 text-right font-bold text-ink">{formatRupiah(order.total)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        </>
      )}
    </AdminShell>
  )
}
