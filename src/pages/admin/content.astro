---
import AdminShell from '@/components/AdminShell.astro';
import { isAdminAuthenticated } from '@/lib/admin/auth';
import { contentCollectionKeys, contentCollections } from '@/lib/admin/content';

export const prerender = false;

if (!(await isAdminAuthenticated(Astro.cookies))) {
  return Astro.redirect(`/admin?next=${encodeURIComponent(Astro.url.pathname)}`);
}
---

<AdminShell title="Content Ibu Kakang" currentPath={Astro.url.pathname}>
  <div class="watercolor-panel p-6 sm:p-8">
    <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Content CMS</p>
    <h1 class="mt-3 font-serif text-4xl font-bold text-ink">Kelola konten toko</h1>
    <p class="mt-3 max-w-2xl text-[#70675e]">Buku, resensi, periode PO, dan halaman dikelola dari database Supabase. Dashboard transaksi tetap terpisah di menu Orders dan Payments.</p>
  </div>

  <section class="mt-6 grid gap-4 md:grid-cols-2">
    {contentCollectionKeys.map((key) => {
      const collection = contentCollections[key];

      return (
        <a class="soft-card block p-5 transition hover:-translate-y-0.5 hover:shadow-soft" href={`/admin/content/${collection.key}`}>
          <p class="text-sm font-bold uppercase tracking-[0.12em] text-date">{collection.singularLabel}</p>
          <h2 class="mt-2 font-serif text-2xl font-bold text-ink">{collection.label}</h2>
          <p class="mt-2 text-sm leading-6 text-[#70675e]">{collection.description}</p>
        </a>
      );
    })}
  </section>
</AdminShell>
