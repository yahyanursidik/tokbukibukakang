---
import AdminShell from '@/components/AdminShell.astro';
import { isAdminAuthenticated } from '@/lib/admin/auth';
import {
  createContentRow,
  deleteContentRow,
  formatContentValue,
  getContentCollection,
  listBookOptions,
  listContentRows,
  parseContentForm
} from '@/lib/admin/content';

export const prerender = false;

if (!(await isAdminAuthenticated(Astro.cookies))) {
  return Astro.redirect(`/admin?next=${encodeURIComponent(Astro.url.pathname)}`);
}

const collection = getContentCollection(Astro.params.collection ?? '');

if (!collection) {
  return new Response(null, { status: 404 });
}

let actionMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = String(formData.get('_action') ?? '');

  try {
    if (action === 'create') {
      await createContentRow(collection, await parseContentForm(collection, formData));
      actionMessage = `${collection.singularLabel} berhasil ditambahkan.`;
    }

    if (action === 'delete') {
      const id = String(formData.get('id') ?? '');
      if (!id) {
        throw new Error('ID konten tidak ditemukan.');
      }
      await deleteContentRow(collection, id);
      actionMessage = `${collection.singularLabel} berhasil dihapus.`;
    }
  } catch (error) {
    errorMessage = error instanceof Error ? error.message : 'Perubahan konten belum berhasil disimpan.';
  }
}

let rows: Awaited<ReturnType<typeof listContentRows>> = [];
let bookOptions: Awaited<ReturnType<typeof listBookOptions>> = [];

try {
  rows = await listContentRows(collection);

  if (collection.key === 'po-periods') {
    bookOptions = await listBookOptions();
  }
} catch (error) {
  errorMessage = error instanceof Error ? error.message : 'Konten belum dapat dimuat.';
}

const isBookCollection = collection.key === 'books';
const wideBookFields = new Set([
  'cover_image',
  'gallery_images',
  'short_description',
  'review_summary',
  'parent_notes',
  'manhaj_notes',
  'external_review_sources'
]);
const getFieldClass = (fieldName: string, isWideType = false) => [
  'grid gap-2 rounded-3xl border border-[#eadcc7] bg-white/68 p-4 text-sm font-bold text-[#5f564e]',
  (isWideType || (isBookCollection && wideBookFields.has(fieldName))) && 'md:col-span-2'
];
---

<AdminShell title={`Ibu Kakang ${collection.label}`} currentPath={Astro.url.pathname}>
  <div class="watercolor-panel p-6 sm:p-8">
    <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Content CMS</p>
    <h1 class="mt-3 font-serif text-4xl font-bold text-ink">{collection.label}</h1>
    <p class="mt-3 max-w-2xl text-[#70675e]">{collection.description}</p>
  </div>

  {actionMessage && <div class="mt-6 rounded-3xl border border-[#b9d8c2] bg-[#edf7ef] p-4 text-sm font-bold text-[#36543c]">{actionMessage}</div>}
  {errorMessage && <div class="mt-6 rounded-3xl border border-date/25 bg-parchment/80 p-4 text-sm font-bold text-date">{errorMessage}</div>}

  <section class="soft-card mt-6 overflow-hidden">
    <div class="flex flex-wrap items-center justify-between gap-3 border-b border-[#eadcc7] p-5">
      <div>
        <h2 class="font-serif text-2xl font-bold text-ink">Daftar {collection.label}</h2>
        <p class="mt-1 text-sm text-[#70675e]">{rows.length} item tersimpan di Supabase.</p>
      </div>
      <a class="rounded-full border border-date/25 bg-white/80 px-4 py-2 text-sm font-bold text-date" href="/admin/content">Semua content</a>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full text-left text-sm">
        <thead class="bg-parchment/70 text-xs uppercase tracking-[0.12em] text-date">
          <tr>
            {collection.listColumns.map((column) => <th class="px-5 py-3">{column.label}</th>)}
            <th class="px-5 py-3 text-right">Aksi</th>
          </tr>
        </thead>
        <tbody>
          {rows.length === 0 ? (
            <tr><td class="px-5 py-8 text-center text-[#70675e]" colspan={collection.listColumns.length + 1}>Belum ada konten.</td></tr>
          ) : rows.map((row) => (
            <tr class="border-t border-[#eadcc7]">
              {collection.listColumns.map((column) => (
                <td class="px-5 py-4 text-[#70675e]">
                  {column.field === 'title' ? (
                    <a class="font-bold text-ink hover:text-date" href={`/admin/content/${collection.key}/${row.id}`}>{formatContentValue(row[column.field], column.type)}</a>
                  ) : (
                    formatContentValue(row[column.field], column.type)
                  )}
                </td>
              ))}
              <td class="px-5 py-4">
                <div class="flex justify-end gap-2">
                  <a class="rounded-full bg-ink px-4 py-2 text-xs font-bold text-cream" href={`/admin/content/${collection.key}/${row.id}`}>Edit</a>
                  <form method="post" onsubmit="return confirm('Hapus konten ini?')">
                    <input type="hidden" name="_action" value="delete" />
                    <input type="hidden" name="id" value={row.id} />
                    <button class="rounded-full border border-date/25 bg-white/80 px-4 py-2 text-xs font-bold text-date" type="submit">Hapus</button>
                  </form>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="soft-card mt-6 p-5 sm:p-6">
    <h2 class="font-serif text-2xl font-bold text-ink">Tambah {collection.singularLabel}</h2>
    {isBookCollection && (
      <div class="mt-4 grid gap-3 text-sm text-[#70675e] md:grid-cols-3">
        <p class="rounded-2xl bg-parchment/70 p-4"><strong class="text-date">Harga PO</strong><br />Isi sebagai harga utama yang masuk keranjang.</p>
        <p class="rounded-2xl bg-parchment/70 p-4"><strong class="text-date">Harga asli</strong><br />Opsional, tampil dicoret agar diskon lebih jelas.</p>
        <p class="rounded-2xl bg-parchment/70 p-4"><strong class="text-date">Gambar buku</strong><br />Cover ditampilkan utuh sebagai thumbnail katalog dan PO.</p>
      </div>
    )}
    <form class="mt-5 grid gap-4 md:grid-cols-2" method="post" enctype="multipart/form-data">
      <input type="hidden" name="_action" value="create" />
      {collection.fields.map((field) => (
        field.type === 'book-multiselect' ? (
          <fieldset class="grid gap-3 text-sm font-bold text-[#5f564e] md:col-span-2">
            <legend>{field.label}</legend>
            {field.hint && <p class="text-xs font-medium text-[#82766b]">{field.hint}</p>}
            {bookOptions.length > 0 ? (
              <div class="grid max-h-80 gap-3 overflow-y-auto rounded-3xl border border-[#eadcc7] bg-white/72 p-3 sm:grid-cols-2">
                {bookOptions.map((book) => (
                  <label class="flex min-h-16 cursor-pointer gap-3 rounded-2xl border border-[#eadcc7]/70 bg-[#fffaf1]/70 p-3 font-normal text-ink transition hover:bg-parchment/70">
                    <input class="mt-1 h-5 w-5 shrink-0 accent-date" name={field.name} type="checkbox" value={book.slug} />
                    <span class="min-w-0">
                      <span class="block font-bold leading-snug">{book.title}</span>
                      <span class="mt-1 block text-xs text-[#70675e]">{book.slug}</span>
                      <span class="mt-2 flex flex-wrap gap-1.5">
                        <span class="rounded-full bg-honey/60 px-2 py-0.5 text-[0.68rem] font-bold text-date">{book.stock_type === 'preorder' ? 'Preorder' : 'Ready stock'}</span>
                        {!book.is_active && <span class="rounded-full bg-rose/45 px-2 py-0.5 text-[0.68rem] font-bold text-date">Nonaktif</span>}
                      </span>
                    </span>
                  </label>
                ))}
              </div>
            ) : (
              <p class="rounded-3xl border border-dashed border-date/25 bg-parchment/60 p-4 text-sm font-semibold text-[#70675e]">
                Belum ada buku di katalog. Tambahkan buku PO terlebih dahulu di Content CMS - Buku, lalu pilih dari daftar ini.
              </p>
            )}
          </fieldset>
        ) : field.type === 'storage-image' ? (
          <label class:list={getFieldClass(field.name, true)}>
            {field.label}
            <input class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name={`${field.name}_file`} type="file" accept="image/jpeg,image/png,image/webp,image/gif" />
            <input class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name={field.name} type="text" placeholder={field.placeholder ?? 'Atau tempel URL/path gambar cover'} />
            {field.hint && <span class="text-xs font-medium text-[#82766b]">{field.hint}</span>}
          </label>
        ) : field.type === 'storage-gallery' ? (
          <label class:list={getFieldClass(field.name, true)}>
            {field.label}
            <input class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name={`${field.name}_files`} type="file" accept="image/jpeg,image/png,image/webp,image/gif" multiple />
            <textarea class="min-h-28 rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name={field.name} placeholder={field.placeholder ?? 'Atau tempel URL galeri, satu URL per baris'}></textarea>
            {field.hint && <span class="text-xs font-medium text-[#82766b]">{field.hint}</span>}
          </label>
        ) : (
          <label class:list={getFieldClass(field.name, field.type === 'textarea' || field.type === 'json' || field.type === 'list')}>
            {field.label}
            {field.type === 'textarea' || field.type === 'json' || field.type === 'list' ? (
              <textarea class="min-h-28 rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name={field.name} required={field.required} placeholder={field.placeholder ?? ''}>{field.type === 'json' ? '[]' : ''}</textarea>
            ) : field.type === 'select' ? (
              <select class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name={field.name} required={field.required}>
                {(field.options ?? []).map((option) => <option value={option.value}>{option.label}</option>)}
              </select>
            ) : field.type === 'boolean' ? (
              <span class="flex items-center gap-3 rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink">
                <input class="h-5 w-5 accent-date" name={field.name} type="checkbox" />
                Ya
              </span>
            ) : (
              <input class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name={field.name} type={field.type === 'number' ? 'number' : field.type === 'date' ? 'date' : 'text'} required={field.required} placeholder={field.placeholder ?? ''} />
            )}
            {field.hint && <span class="text-xs font-medium text-[#82766b]">{field.hint}</span>}
          </label>
        )
      ))}
      <div class="md:col-span-2">
        <button class="rounded-full bg-ink px-6 py-3 text-sm font-bold text-cream transition hover:-translate-y-0.5 hover:bg-date" type="submit">
          Simpan {collection.singularLabel}
        </button>
      </div>
    </form>
  </section>
</AdminShell>
