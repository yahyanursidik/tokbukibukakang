---
import AdminShell from '@/components/AdminShell.astro';
import AdminFormEnhancer from '@/components/AdminFormEnhancer.astro';
import { isAdminAuthenticated } from '@/lib/admin/auth';
import {
  getContentCollection,
  getContentRow,
  getFormValue,
  getSelectedContentValues,
  listBookOptions,
  parseContentForm,
  updateContentRow
} from '@/lib/admin/content';

export const prerender = false;

if (!(await isAdminAuthenticated(Astro.cookies))) {
  return Astro.redirect(`/admin?next=${encodeURIComponent(Astro.url.pathname)}`);
}

const collection = getContentCollection(Astro.params.collection ?? '');
const id = Astro.params.id ?? '';

if (!collection || !id) {
  return new Response(null, { status: 404 });
}

let actionMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();

  try {
    await updateContentRow(collection, id, await parseContentForm(collection, formData));
    actionMessage = `${collection.singularLabel} berhasil diperbarui dan perubahan sudah tersimpan di Supabase.`;
  } catch (error) {
    errorMessage = error instanceof Error ? error.message : 'Konten belum berhasil diperbarui.';
  }
}

let row: Awaited<ReturnType<typeof getContentRow>> | null = null;
let bookOptions: Awaited<ReturnType<typeof listBookOptions>> = [];

try {
  row = await getContentRow(collection, id);

  if (collection.key === 'po-periods') {
    bookOptions = await listBookOptions();
  }
} catch (error) {
  return new Response(null, { status: 404 });
}

const isBookCollection = collection.key === 'books';
const wideBookFields = new Set([
  'cover_image',
  'gallery_images',
  'short_description',
  'review_summary',
  'parent_notes',
  'manhaj_notes',
  'external_review_sources'
]);
const getFieldClass = (fieldName: string, isWideType = false) => [
  'grid gap-2 rounded-3xl border border-[#eadcc7] bg-white/68 p-4 text-sm font-bold text-[#5f564e]',
  (isWideType || (isBookCollection && wideBookFields.has(fieldName))) && 'md:col-span-2'
];
---

<AdminShell title={`Edit ${collection.singularLabel}`} currentPath={Astro.url.pathname}>
  <div class="watercolor-panel p-6 sm:p-8">
    <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Edit {collection.singularLabel}</p>
    <h1 class="mt-3 font-serif text-4xl font-bold text-ink">{row.title}</h1>
    <p class="mt-3 text-[#70675e]">Slug: {row.slug}</p>
  </div>

  {actionMessage && <div class="mt-6 rounded-3xl border border-[#b9d8c2] bg-[#edf7ef] p-4 text-sm font-bold text-[#36543c]">{actionMessage}</div>}
  {errorMessage && <div class="mt-6 rounded-3xl border border-date/25 bg-parchment/80 p-4 text-sm font-bold text-date">{errorMessage}</div>}

  <section class="soft-card mt-6 p-5 sm:p-6">
    {isBookCollection && (
      <div class="mb-5 grid gap-3 text-sm text-[#70675e] md:grid-cols-3">
        <p class="rounded-2xl bg-parchment/70 p-4"><strong class="text-date">Harga PO</strong><br />Harga utama yang dipakai checkout.</p>
        <p class="rounded-2xl bg-parchment/70 p-4"><strong class="text-date">Harga asli</strong><br />Isi lebih besar dari harga PO agar tampil dicoret.</p>
        <p class="rounded-2xl bg-parchment/70 p-4"><strong class="text-date">Cover utuh</strong><br />Preview cover memakai object-fit contain supaya tidak terpotong.</p>
      </div>
    )}
    <form class="grid gap-4 md:grid-cols-2" method="post" enctype="multipart/form-data" data-admin-feedback-form>
      {collection.fields.map((field) => (
        field.type === 'book-multiselect' ? (
          <fieldset class="grid gap-3 text-sm font-bold text-[#5f564e] md:col-span-2">
            <legend>{field.label}</legend>
            {field.hint && <p class="text-xs font-medium text-[#82766b]">{field.hint}</p>}
            {bookOptions.length > 0 ? (
              <div class="grid max-h-80 gap-3 overflow-y-auto rounded-3xl border border-[#eadcc7] bg-white/72 p-3 sm:grid-cols-2">
                {bookOptions.map((book) => {
                  const selectedBookSlugs = getSelectedContentValues(row, field);

                  return (
                    <label class="flex min-h-16 cursor-pointer gap-3 rounded-2xl border border-[#eadcc7]/70 bg-[#fffaf1]/70 p-3 font-normal text-ink transition hover:bg-parchment/70">
                      <input class="mt-1 h-5 w-5 shrink-0 accent-date" name={field.name} type="checkbox" value={book.slug} checked={selectedBookSlugs.includes(book.slug)} />
                      <span class="min-w-0">
                        <span class="block font-bold leading-snug">{book.title}</span>
                        <span class="mt-1 block text-xs text-[#70675e]">{book.slug}</span>
                        <span class="mt-2 flex flex-wrap gap-1.5">
                          <span class="rounded-full bg-honey/60 px-2 py-0.5 text-[0.68rem] font-bold text-date">{book.stock_type === 'preorder' ? 'Preorder' : 'Ready stock'}</span>
                          {!book.is_active && <span class="rounded-full bg-rose/45 px-2 py-0.5 text-[0.68rem] font-bold text-date">Nonaktif</span>}
                        </span>
                      </span>
                    </label>
                  );
                })}
              </div>
            ) : (
              <p class="rounded-3xl border border-dashed border-date/25 bg-parchment/60 p-4 text-sm font-semibold text-[#70675e]">
                Belum ada buku di katalog. Tambahkan buku PO terlebih dahulu di Content CMS - Buku, lalu pilih dari daftar ini.
              </p>
            )}
          </fieldset>
        ) : field.type === 'storage-image' ? (
          <label class:list={getFieldClass(field.name, true)} data-upload-field>
            {field.label}
            {getFormValue(row, field) && (
              <img class="aspect-[3/4] w-full max-w-xs rounded-3xl border border-[#eadcc7] bg-parchment object-contain p-3 shadow-soft" src={String(getFormValue(row, field))} alt={`${field.label} saat ini`} loading="lazy" />
            )}
            <input
              class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30"
              name={`${field.name}_file`}
              type="file"
              accept="image/jpeg,image/png,image/webp,image/gif"
              data-upload-input
              data-direct-upload-bucket="book-media"
              data-direct-upload-field={field.name}
              data-direct-upload-target={field.name}
              data-direct-upload-mode="replace"
            />
            <div class="hidden rounded-3xl border border-[#eadcc7] bg-parchment/55 p-3" data-upload-preview>
              <p class="text-xs font-semibold leading-5 text-[#70675e]" data-upload-preview-status>Belum ada file dipilih.</p>
              <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-3" data-upload-preview-list></div>
            </div>
            <input class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name={field.name} type="text" value={String(getFormValue(row, field) ?? '')} placeholder={field.placeholder ?? 'Atau tempel URL/path gambar cover'} />
            {field.hint && <span class="text-xs font-medium text-[#82766b]">{field.hint}</span>}
          </label>
        ) : field.type === 'storage-gallery' ? (
          <label class:list={getFieldClass(field.name, true)} data-upload-field>
            {field.label}
            {getSelectedContentValues(row, field).length > 0 && (
              <div class="grid gap-3 rounded-3xl border border-[#eadcc7] bg-white/72 p-3 sm:grid-cols-2 lg:grid-cols-3">
                {getSelectedContentValues(row, field).map((imageUrl) => (
                  <img class="aspect-[4/3] w-full rounded-2xl bg-parchment object-contain p-2" src={imageUrl} alt="Gambar galeri produk" loading="lazy" />
                ))}
              </div>
            )}
            <input
              class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30"
              name={`${field.name}_files`}
              type="file"
              accept="image/jpeg,image/png,image/webp,image/gif"
              multiple
              data-upload-input
              data-direct-upload-bucket="book-media"
              data-direct-upload-field={field.name}
              data-direct-upload-target={field.name}
              data-direct-upload-mode="append-lines"
            />
            <div class="hidden rounded-3xl border border-[#eadcc7] bg-parchment/55 p-3" data-upload-preview>
              <p class="text-xs font-semibold leading-5 text-[#70675e]" data-upload-preview-status>Belum ada file dipilih.</p>
              <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-3" data-upload-preview-list></div>
            </div>
            <textarea class="min-h-28 rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name={field.name} placeholder={field.placeholder ?? 'Satu URL galeri per baris'}>{getFormValue(row, field)}</textarea>
            {field.hint && <span class="text-xs font-medium text-[#82766b]">{field.hint}</span>}
          </label>
        ) : (
          <label class:list={getFieldClass(field.name, field.type === 'textarea' || field.type === 'json' || field.type === 'list')}>
            {field.label}
            {field.type === 'textarea' || field.type === 'json' || field.type === 'list' ? (
              <textarea class="min-h-28 rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name={field.name} required={field.required} placeholder={field.placeholder ?? ''}>{getFormValue(row, field)}</textarea>
            ) : field.type === 'select' ? (
              <select class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name={field.name} required={field.required}>
                {(field.options ?? []).map((option) => <option value={option.value} selected={getFormValue(row, field) === option.value}>{option.label}</option>)}
              </select>
            ) : field.type === 'boolean' ? (
              <span class="flex items-center gap-3 rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink">
                <input class="h-5 w-5 accent-date" name={field.name} type="checkbox" checked={Boolean(getFormValue(row, field))} />
                Ya
              </span>
            ) : (
              <input
                class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30 read-only:bg-parchment/70 read-only:text-[#70675e]"
                name={field.name}
                type={field.type === 'number' ? 'number' : field.type === 'date' ? 'date' : 'text'}
                value={String(getFormValue(row, field) ?? '')}
                required={field.required}
                placeholder={field.placeholder ?? ''}
                readonly={field.name === 'slug'}
                data-auto-slug-title={field.name === 'title' ? 'true' : undefined}
                data-auto-slug-input={field.name === 'slug' ? 'true' : undefined}
              />
            )}
            {field.hint && <span class="text-xs font-medium text-[#82766b]">{field.hint}</span>}
          </label>
        )
      ))}
      <div class="flex flex-wrap gap-3 md:col-span-2">
        {(actionMessage || errorMessage) && (
          <div
            class={`w-full rounded-3xl border p-4 text-sm font-bold ${
              actionMessage
                ? 'border-[#b9d8c2] bg-[#edf7ef] text-[#36543c]'
                : 'border-date/25 bg-parchment/80 text-date'
            }`}
            role="status"
            aria-live="polite"
          >
            <span class="block text-xs uppercase tracking-[0.14em] opacity-75">
              {actionMessage ? 'Perubahan tersimpan' : 'Belum tersimpan'}
            </span>
            <span class="mt-1 block leading-6">{actionMessage || errorMessage}</span>
          </div>
        )}
        <div class="hidden w-full rounded-3xl border border-[#b9d8c2] bg-[#edf7ef] p-4 text-sm font-bold text-[#36543c]" data-submit-feedback role="status" aria-live="polite">
          <div class="flex items-center justify-between gap-3">
            <span data-submit-message>Menyimpan...</span>
            <span data-submit-percent>0%</span>
          </div>
          <div class="mt-3 h-2 overflow-hidden rounded-full bg-white/80">
            <div class="h-full w-0 rounded-full bg-[#36543c] transition-all duration-300" data-submit-progress></div>
          </div>
        </div>
        <button class="rounded-full bg-ink px-6 py-3 text-sm font-bold text-cream transition hover:-translate-y-0.5 hover:bg-date disabled:hover:translate-y-0" type="submit" data-loading-label="Menyimpan perubahan...">
          Simpan perubahan
        </button>
        <a class="rounded-full border border-date/25 bg-white/80 px-6 py-3 text-sm font-bold text-date" href={`/admin/content/${collection.key}`}>
          Kembali
        </a>
      </div>
    </form>
  </section>
  <AdminFormEnhancer />
</AdminShell>
