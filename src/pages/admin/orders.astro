---
import AdminShell from '@/components/AdminShell.astro';
import { isAdminAuthenticated } from '@/lib/admin/auth';
import {
  formatDateTime,
  formatRupiah,
  listAdminOrders,
  orderStatusOptions,
  paymentStatusOptions,
  statusLabel
} from '@/lib/admin/orders';

export const prerender = false;

if (!(await isAdminAuthenticated(Astro.cookies))) {
  return Astro.redirect(`/admin?next=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`);
}

const paymentStatus = Astro.url.searchParams.get('payment_status') ?? '';
const orderStatus = Astro.url.searchParams.get('order_status') ?? '';
const search = Astro.url.searchParams.get('q') ?? '';
let orders: Awaited<ReturnType<typeof listAdminOrders>> = [];
let errorMessage = '';

try {
  orders = await listAdminOrders({ paymentStatus, orderStatus, search });
} catch (error) {
  errorMessage = error instanceof Error ? error.message : 'Order belum dapat dimuat.';
}
---

<AdminShell title="Orders Ibu Kakang" currentPath={Astro.url.pathname}>
  <div class="watercolor-panel p-6 sm:p-8">
    <div class="grid gap-4 lg:grid-cols-[1fr_auto] lg:items-end">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Orders</p>
        <h1 class="mt-3 font-serif text-4xl font-bold text-ink">Daftar order</h1>
        <p class="mt-3 max-w-2xl text-[#70675e]">
          Buat invoice dari order yang sudah masuk, lalu kirim template WhatsApp manual ke customer.
        </p>
      </div>
      <a class="rounded-full bg-ink px-5 py-3 text-sm font-bold text-cream transition hover:-translate-y-0.5 hover:bg-date" href="/admin/orders/new">
        Buat Invoice
      </a>
    </div>
  </div>

  <form class="soft-card mt-6 grid gap-4 p-5 lg:grid-cols-[1fr_220px_220px_auto]" method="get">
    <input class="rounded-full border border-[#eadcc7] bg-white/80 px-4 py-3 text-sm outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name="q" value={search} placeholder="Cari invoice, nama, WhatsApp" />
    <select class="rounded-full border border-[#eadcc7] bg-white/80 px-4 py-3 text-sm outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name="payment_status">
      <option value="">Semua payment</option>
      {paymentStatusOptions.map((status) => <option value={status} selected={paymentStatus === status}>{statusLabel(status)}</option>)}
    </select>
    <select class="rounded-full border border-[#eadcc7] bg-white/80 px-4 py-3 text-sm outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name="order_status">
      <option value="">Semua order</option>
      {orderStatusOptions.map((status) => <option value={status} selected={orderStatus === status}>{statusLabel(status)}</option>)}
    </select>
    <button class="rounded-full bg-ink px-5 py-3 text-sm font-bold text-cream" type="submit">Filter</button>
  </form>

  {errorMessage ? (
    <div class="mt-6 rounded-3xl border border-date/25 bg-parchment/80 p-5 text-sm font-bold text-date">{errorMessage}</div>
  ) : (
    <section class="soft-card mt-6 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full text-left text-sm">
          <thead class="bg-parchment/70 text-xs uppercase tracking-[0.12em] text-date">
            <tr>
              <th class="px-5 py-3">Invoice</th>
              <th class="px-5 py-3">Customer</th>
              <th class="px-5 py-3">WhatsApp</th>
              <th class="px-5 py-3">Payment</th>
              <th class="px-5 py-3">Order</th>
              <th class="px-5 py-3 text-right">Total</th>
              <th class="px-5 py-3 text-right">Invoice</th>
            </tr>
          </thead>
          <tbody>
            {orders.length === 0 ? (
              <tr><td class="px-5 py-8 text-center text-[#70675e]" colspan="7">Tidak ada order yang cocok.</td></tr>
            ) : orders.map((order) => (
              <tr class="border-t border-[#eadcc7]">
                <td class="px-5 py-4 font-bold text-ink"><a class="hover:text-date" href={`/admin/orders/${order.id}`}>{order.order_number}</a><br /><span class="text-xs font-medium text-[#70675e]">{formatDateTime(order.created_at)}</span></td>
                <td class="px-5 py-4 text-[#70675e]">{order.customer_name}</td>
                <td class="px-5 py-4 text-[#70675e]">{order.customer_phone}</td>
                <td class="px-5 py-4"><span class="rounded-full bg-honey px-3 py-1 text-xs font-bold text-date">{statusLabel(order.payment_status)}</span></td>
                <td class="px-5 py-4"><span class="rounded-full bg-parchment px-3 py-1 text-xs font-bold text-ink">{statusLabel(order.status)}</span></td>
                <td class="px-5 py-4 text-right font-bold text-ink">{formatRupiah(order.total)}</td>
                <td class="px-5 py-4">
                  <div class="flex flex-wrap justify-end gap-2">
                    <a class="rounded-full bg-ink px-3 py-1.5 text-xs font-bold text-cream" href={`/admin/orders/${order.id}#invoice-whatsapp`}>
                      Buat Invoice
                    </a>
                    <a class="rounded-full border border-date/25 bg-white/80 px-3 py-1.5 text-xs font-bold text-date" href={`/invoice/${order.invoice_token}`} target="_blank" rel="noreferrer">
                      Lihat Invoice
                    </a>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}
</AdminShell>
