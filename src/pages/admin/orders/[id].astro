---
import AdminShell from '@/components/AdminShell.astro';
import { isAdminAuthenticated } from '@/lib/admin/auth';
import {
  createInvoiceLog,
  formatDateTime,
  formatRupiah,
  getAdminOrderDetail,
  orderStatusOptions,
  paymentStatusOptions,
  statusLabel,
  updateOrderStatus,
  type OrderStatus,
  type PaymentStatus
} from '@/lib/admin/orders';
import { buildPaymentInstructionText, getPaymentSettings } from '@/lib/admin/settings';

export const prerender = false;

if (!(await isAdminAuthenticated(Astro.cookies))) {
  return Astro.redirect(`/admin?next=${encodeURIComponent(Astro.url.pathname)}`);
}

const { id } = Astro.params;
let actionMessage = '';
let errorMessage = '';

if (!id) {
  return Astro.redirect('/admin/orders');
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = String(formData.get('_action') ?? 'update_status');
  const status = String(formData.get('status') ?? '') as OrderStatus;
  const paymentStatus = String(formData.get('payment_status') ?? '') as PaymentStatus;

  try {
    if (action === 'create_invoice_log') {
      const recipient = String(formData.get('recipient') ?? '').trim();
      const message = String(formData.get('message') ?? '').trim();

      if (!recipient || !message) {
        throw new Error('Nomor penerima dan isi invoice wajib tersedia.');
      }

      await createInvoiceLog({ orderId: id, recipient, message });
      actionMessage = 'Invoice berhasil dicatat. Silakan kirim manual melalui WhatsApp.';
    } else {
      await updateOrderStatus(id, {
        status: orderStatusOptions.includes(status) ? status : undefined,
        paymentStatus: paymentStatusOptions.includes(paymentStatus) ? paymentStatus : undefined
      });
      actionMessage = 'Status order berhasil diperbarui.';
    }
  } catch (error) {
    errorMessage = error instanceof Error ? error.message : 'Perubahan order belum berhasil disimpan.';
  }
}

let detail: Awaited<ReturnType<typeof getAdminOrderDetail>> | null = null;
let paymentSettings: Awaited<ReturnType<typeof getPaymentSettings>> | null = null;

try {
  [detail, paymentSettings] = await Promise.all([getAdminOrderDetail(id), getPaymentSettings()]);
} catch (error) {
  errorMessage = error instanceof Error ? error.message : 'Detail order belum dapat dimuat.';
}

const brandName = 'Ibu Kakang BookStore';

const normalizeWhatsappNumber = (value: string) => {
  const digits = value.replace(/\D/g, '');

  if (digits.startsWith('62')) {
    return digits;
  }

  if (digits.startsWith('0')) {
    return `62${digits.slice(1)}`;
  }

  return digits;
};

const buildItemList = (items: NonNullable<typeof detail>['items']) =>
  items
    .map((item, index) => `${index + 1}. ${item.title}\n   ${item.quantity} x ${formatRupiah(item.price)} = ${formatRupiah(item.subtotal)}`)
    .join('\n');

const buildInvoiceTemplates = (orderDetail: NonNullable<typeof detail>) => {
  const { order, items } = orderDetail;
  const invoiceLink = `${Astro.url.origin}/invoice/${order.invoice_token}`;
  const paymentConfirmationLink = `${Astro.url.origin}/konfirmasi-pembayaran?invoice=${encodeURIComponent(order.order_number)}`;
  const paymentInstruction = paymentSettings
    ? buildPaymentInstructionText(paymentSettings)
    : 'Metode pembayaran akan dikonfirmasi admin.';
  const paymentConfirmationNotes =
    paymentSettings?.payment_confirmation_notes ||
    'Setelah transfer, mohon konfirmasi pembayaran melalui halaman konfirmasi.';
  const invoiceFooter =
    paymentSettings?.invoice_footer ||
    'Semoga Allah memberkahi keluarga Bapak/Ibu dan menjadikan bacaan ini bermanfaat.';
  const itemList = buildItemList(items);
  const shippingLine =
    order.shipping_cost > 0
      ? `Ongkir: ${formatRupiah(order.shipping_cost)}`
      : 'Ongkir: akan dikonfirmasi admin jika ada penyesuaian.';
  const customerName = order.customer_name || 'Bapak/Ibu';
  const invoiceText = [
    `Assalamu'alaikum warahmatullahi wabarakatuh, ${customerName}.`,
    '',
    `Terima kasih sudah berbelanja di ${brandName}. Berikut invoice pesanan Bapak/Ibu:`,
    '',
    `Invoice: ${order.order_number}`,
    `Tautan invoice: ${invoiceLink}`,
    '',
    'Daftar pesanan:',
    itemList || '-',
    '',
    `Subtotal: ${formatRupiah(order.subtotal)}`,
    shippingLine,
    `Total: ${formatRupiah(order.total)}`,
    '',
    'Instruksi pembayaran:',
    paymentInstruction,
    '',
    paymentConfirmationNotes,
    paymentConfirmationLink,
    '',
    invoiceFooter,
    '',
    `Barakallahu fiikum,`,
    brandName
  ].join('\n');

  return [
    {
      key: 'invoice',
      label: 'Invoice',
      description: 'Kirim invoice lengkap dan instruksi transfer.',
      message: invoiceText
    },
    {
      key: 'payment-reminder',
      label: 'Payment reminder',
      description: 'Pengingat lembut untuk invoice yang belum dibayar.',
      message: [
        `Assalamu'alaikum warahmatullahi wabarakatuh, ${customerName}.`,
        '',
        `Izin mengingatkan invoice ${order.order_number} dari ${brandName}.`,
        `Total sementara: ${formatRupiah(order.total)}.`,
        `Tautan invoice: ${invoiceLink}`,
        '',
        'Jika Bapak/Ibu sudah transfer, mohon abaikan pesan ini dan silakan kirim konfirmasi pembayaran melalui:',
        paymentConfirmationLink,
        '',
        'Jazakumullahu khairan, semoga Allah mudahkan urusannya.',
        brandName
      ].join('\n')
    },
    {
      key: 'payment-confirmed',
      label: 'Payment confirmed',
      description: 'Kabarkan pembayaran sudah diverifikasi admin.',
      message: [
        `Assalamu'alaikum warahmatullahi wabarakatuh, ${customerName}.`,
        '',
        `Alhamdulillah, pembayaran untuk invoice ${order.order_number} sudah kami verifikasi.`,
        'Pesanan akan masuk ke proses persiapan sesuai jadwal ketersediaan buku.',
        '',
        'Barakallahu fiikum atas kepercayaannya.',
        brandName
      ].join('\n')
    },
    {
      key: 'packing-update',
      label: 'Packing update',
      description: 'Update saat pesanan sedang disiapkan.',
      message: [
        `Assalamu'alaikum warahmatullahi wabarakatuh, ${customerName}.`,
        '',
        `Pesanan invoice ${order.order_number} sedang kami siapkan dan packing dengan hati-hati.`,
        'InsyaAllah kami kabari kembali setelah paket diserahkan ke ekspedisi.',
        '',
        'Semoga Allah mudahkan prosesnya.',
        brandName
      ].join('\n')
    },
    {
      key: 'shipping-update',
      label: 'Shipping update',
      description: 'Update saat paket sudah dikirim.',
      message: [
        `Assalamu'alaikum warahmatullahi wabarakatuh, ${customerName}.`,
        '',
        `Pesanan invoice ${order.order_number} sudah kami serahkan ke ekspedisi.`,
        'Nomor resi dapat kami kirimkan di pesan berikutnya atau setelah sistem ekspedisi memperbarui data.',
        '',
        'Mohon ditunggu dengan tenang, semoga paket tiba dalam keadaan baik.',
        brandName
      ].join('\n')
    },
    {
      key: 'completed-order',
      label: 'Completed order',
      description: 'Tutup order setelah paket diterima.',
      message: [
        `Assalamu'alaikum warahmatullahi wabarakatuh, ${customerName}.`,
        '',
        `Alhamdulillah, pesanan invoice ${order.order_number} kami tandai selesai.`,
        'Semoga buku-bukunya menjadi teman tumbuh yang baik dan membawa manfaat untuk keluarga.',
        '',
        'Jazakumullahu khairan sudah berbelanja di Ibu Kakang BookStore.',
        'Semoga Allah memberkahi waktu belajar dan membaca bersama anak-anak.',
        brandName
      ].join('\n')
    }
  ];
};

const invoiceTemplates = detail ? buildInvoiceTemplates(detail) : [];
const whatsappNumber = detail ? normalizeWhatsappNumber(detail.order.customer_phone) : '';
const invoiceUrl = detail ? `${Astro.url.origin}/invoice/${detail.order.invoice_token}` : '';
---

<AdminShell title="Order Detail" currentPath={Astro.url.pathname}>
  {errorMessage && !detail ? (
    <div class="rounded-3xl border border-date/25 bg-parchment/80 p-5 text-sm font-bold text-date">{errorMessage}</div>
  ) : detail && (
    <>
      <div class="watercolor-panel p-6 sm:p-8">
        <a class="text-sm font-bold text-date hover:text-ink" href="/admin/orders">Kembali ke orders</a>
        <h1 class="mt-3 font-serif text-4xl font-bold text-ink">{detail.order.order_number}</h1>
        <p class="mt-2 text-[#70675e]">Dibuat {formatDateTime(detail.order.created_at)}</p>
      </div>

      {actionMessage && <div class="mt-6 rounded-3xl border border-[#b9d8c2] bg-[#edf7ef] p-4 text-sm font-bold text-[#36543c]">{actionMessage}</div>}
      {errorMessage && <div class="mt-6 rounded-3xl border border-date/25 bg-parchment/80 p-4 text-sm font-bold text-date">{errorMessage}</div>}

      <div class="mt-6 grid gap-6 lg:grid-cols-[1fr_360px]">
        <section class="grid gap-6">
          <article class="soft-card overflow-hidden" id="invoice-whatsapp">
            <div class="grid gap-4 border-b border-[#eadcc7] p-5 lg:grid-cols-[1fr_auto] lg:items-start">
              <div>
                <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Invoice WhatsApp</p>
                <h2 class="mt-2 font-serif text-2xl font-bold text-ink">Preview dan template pesan</h2>
                <p class="mt-2 text-sm text-[#70675e]">
                  Pilih template, tinjau isi pesan, lalu copy atau buka WhatsApp. Pesan tidak dikirim otomatis.
                </p>
              </div>
              <div class="flex flex-wrap gap-2">
                <a
                  class="rounded-full border border-date/25 bg-white/80 px-4 py-2 text-sm font-bold text-date transition hover:-translate-y-0.5 hover:bg-parchment"
                  href={invoiceUrl}
                  target="_blank"
                  rel="noreferrer"
                >
                  Buka invoice
                </a>
                <button
                  class="rounded-full border border-date/25 bg-white/80 px-4 py-2 text-sm font-bold text-date transition hover:-translate-y-0.5 hover:bg-parchment"
                  type="button"
                  data-invoice-link-copy
                  data-invoice-url={invoiceUrl}
                >
                  Copy link invoice
                </button>
                <button
                  class="rounded-full bg-ink px-4 py-2 text-sm font-bold text-cream transition hover:-translate-y-0.5 hover:bg-date"
                  type="button"
                  data-invoice-copy
                >
                  Copy invoice text
                </button>
                <a
                  class="rounded-full border border-date/25 bg-white/80 px-4 py-2 text-sm font-bold text-date transition hover:-translate-y-0.5 hover:bg-parchment"
                  href={`https://wa.me/${whatsappNumber}`}
                  target="_blank"
                  rel="noreferrer"
                  data-invoice-whatsapp
                >
                  Open WhatsApp
                </a>
              </div>
            </div>

            <form class="border-b border-[#eadcc7] bg-parchment/45 p-5" method="post" data-invoice-log-form>
              <input type="hidden" name="_action" value="create_invoice_log" />
              <input type="hidden" name="recipient" value={whatsappNumber || detail.order.customer_phone} />
              <input type="hidden" name="message" value={invoiceTemplates[0]?.message ?? ''} data-invoice-log-message />
              <button class="rounded-full bg-date px-5 py-2.5 text-sm font-bold text-cream transition hover:-translate-y-0.5 hover:bg-ink" type="submit">
                Catat invoice dibuat
              </button>
              <p class="mt-2 text-xs font-medium text-[#70675e]">
                Catatan ini masuk ke invoice log. Pengiriman tetap manual melalui wa.me.
              </p>
            </form>

            <div class="grid gap-5 p-5 xl:grid-cols-[260px_1fr]">
              <div class="grid h-fit gap-2" role="list" aria-label="Template WhatsApp">
                {invoiceTemplates.map((template, index) => (
                  <button
                    class="rounded-3xl border border-[#eadcc7] bg-white/70 p-4 text-left transition hover:border-date/40 hover:bg-parchment/70 data-[active=true]:border-date/40 data-[active=true]:bg-honey/35"
                    type="button"
                    data-template-button
                    data-template-key={template.key}
                    data-active={index === 0}
                  >
                    <span class="block text-sm font-bold text-ink">{template.label}</span>
                    <span class="mt-1 block text-xs font-medium leading-relaxed text-[#70675e]">{template.description}</span>
                  </button>
                ))}
              </div>

              <div class="grid gap-3">
                <textarea
                  class="min-h-[420px] w-full rounded-[24px] border border-[#eadcc7] bg-[#fffaf1]/86 p-4 font-mono text-sm leading-relaxed text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30"
                  readonly
                  data-invoice-preview
                >{invoiceTemplates[0]?.message ?? ''}</textarea>
                <p class="hidden rounded-3xl border border-[#b9d8c2] bg-[#edf7ef] p-3 text-sm font-bold text-[#36543c]" data-invoice-copy-status>
                  Teks invoice tersalin.
                </p>
                <p class="hidden rounded-3xl border border-[#b9d8c2] bg-[#edf7ef] p-3 text-sm font-bold text-[#36543c]" data-invoice-link-copy-status>
                  Tautan invoice tersalin.
                </p>
              </div>
            </div>

            <script is:inline type="application/json" data-invoice-templates set:html={JSON.stringify(invoiceTemplates)} />
            <script is:inline type="application/json" data-whatsapp-number set:html={JSON.stringify(whatsappNumber)} />
          </article>

          <article class="soft-card p-5">
            <h2 class="font-serif text-2xl font-bold text-ink">Customer data</h2>
            <dl class="mt-4 grid gap-3 text-sm sm:grid-cols-2">
              <div><dt class="font-bold text-date">Nama</dt><dd class="text-[#70675e]">{detail.order.customer_name}</dd></div>
              <div><dt class="font-bold text-date">WhatsApp</dt><dd class="text-[#70675e]">{detail.order.customer_phone}</dd></div>
              <div><dt class="font-bold text-date">Email</dt><dd class="text-[#70675e]">{detail.order.customer_email ?? '-'}</dd></div>
              <div><dt class="font-bold text-date">Alamat</dt><dd class="whitespace-pre-line text-[#70675e]">{detail.order.customer_address ?? '-'}</dd></div>
              <div class="sm:col-span-2"><dt class="font-bold text-date">Catatan</dt><dd class="whitespace-pre-line text-[#70675e]">{detail.order.notes ?? '-'}</dd></div>
            </dl>
          </article>

          <article class="soft-card overflow-hidden">
            <h2 class="p-5 font-serif text-2xl font-bold text-ink">Order items</h2>
            <div class="overflow-x-auto">
              <table class="min-w-full text-left text-sm">
                <thead class="bg-parchment/70 text-xs uppercase tracking-[0.12em] text-date">
                  <tr><th class="px-5 py-3">Buku</th><th class="px-5 py-3">Qty</th><th class="px-5 py-3 text-right">Harga</th><th class="px-5 py-3 text-right">Subtotal</th></tr>
                </thead>
                <tbody>
                  {detail.items.map((item) => (
                    <tr class="border-t border-[#eadcc7]">
                      <td class="px-5 py-4 font-bold text-ink">{item.title}<br /><span class="text-xs font-medium text-[#70675e]">{item.book_slug}</span></td>
                      <td class="px-5 py-4 text-[#70675e]">{item.quantity}</td>
                      <td class="px-5 py-4 text-right text-[#70675e]">{formatRupiah(item.price)}</td>
                      <td class="px-5 py-4 text-right font-bold text-ink">{formatRupiah(item.subtotal)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </article>

          <article class="soft-card overflow-hidden">
            <h2 class="p-5 font-serif text-2xl font-bold text-ink">Payment confirmations</h2>
            <div class="grid gap-3 p-5 pt-0">
              {detail.confirmations.length === 0 ? (
                <p class="rounded-3xl bg-parchment/70 p-4 text-sm text-[#70675e]">Belum ada konfirmasi pembayaran.</p>
              ) : detail.confirmations.map((confirmation) => (
                <div class="rounded-3xl border border-[#eadcc7] bg-white/70 p-4">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div>
                      <p class="font-bold text-ink">{confirmation.sender_name}</p>
                      <p class="text-sm text-[#70675e]">{confirmation.bank_name ?? '-'} - {formatRupiah(confirmation.amount)}</p>
                      <p class="text-xs text-[#70675e]">Transfer {confirmation.transfer_date} - masuk {formatDateTime(confirmation.created_at)}</p>
                    </div>
                    <span class="rounded-full bg-honey px-3 py-1 text-xs font-bold text-date">{statusLabel(confirmation.status)}</span>
                  </div>
                  {confirmation.customer_note && <p class="mt-3 text-sm text-[#70675e]">{confirmation.customer_note}</p>}
                  {confirmation.proof_url && <a class="mt-3 inline-flex text-sm font-bold text-date hover:text-ink" href={confirmation.proof_url} target="_blank" rel="noreferrer">Lihat bukti transfer</a>}
                </div>
              ))}
            </div>
          </article>
        </section>

        <aside class="grid h-fit gap-6 lg:sticky lg:top-28">
          <article class="soft-card p-5">
            <h2 class="font-serif text-2xl font-bold text-ink">Ringkasan</h2>
            <dl class="mt-4 grid gap-3 text-sm">
              <div class="flex justify-between gap-4"><dt class="text-[#70675e]">Subtotal</dt><dd class="font-bold text-ink">{formatRupiah(detail.order.subtotal)}</dd></div>
              <div class="flex justify-between gap-4"><dt class="text-[#70675e]">Ongkir</dt><dd class="font-bold text-ink">{formatRupiah(detail.order.shipping_cost)}</dd></div>
              <div class="flex justify-between gap-4 border-t border-[#eadcc7] pt-3"><dt class="font-bold text-date">Total</dt><dd class="font-serif text-2xl font-bold text-ink">{formatRupiah(detail.order.total)}</dd></div>
            </dl>
          </article>

          <form class="soft-card grid gap-4 p-5" method="post">
            <input type="hidden" name="_action" value="update_status" />
            <h2 class="font-serif text-2xl font-bold text-ink">Update status</h2>
            <label class="grid gap-2 text-sm font-bold text-[#5f564e]">
              Payment status
              <select class="rounded-full border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal outline-none" name="payment_status">
                {paymentStatusOptions.map((status) => <option value={status} selected={detail.order.payment_status === status}>{statusLabel(status)}</option>)}
              </select>
            </label>
            <label class="grid gap-2 text-sm font-bold text-[#5f564e]">
              Order status
              <select class="rounded-full border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal outline-none" name="status">
                {orderStatusOptions.map((status) => <option value={status} selected={detail.order.status === status}>{statusLabel(status)}</option>)}
              </select>
            </label>
            <button class="rounded-full bg-ink px-5 py-3 text-sm font-bold text-cream" type="submit">Simpan status</button>
          </form>
        </aside>
      </div>
    </>
  )}
</AdminShell>

<script>
  type InvoiceTemplate = {
    key: string;
    label: string;
    description: string;
    message: string;
  };

  const templatesElement = document.querySelector<HTMLScriptElement>('[data-invoice-templates]');
  const whatsappNumberElement = document.querySelector<HTMLScriptElement>('[data-whatsapp-number]');
  const previewElement = document.querySelector<HTMLTextAreaElement>('[data-invoice-preview]');
  const copyButton = document.querySelector<HTMLButtonElement>('[data-invoice-copy]');
  const copyLinkButton = document.querySelector<HTMLButtonElement>('[data-invoice-link-copy]');
  const whatsappLink = document.querySelector<HTMLAnchorElement>('[data-invoice-whatsapp]');
  const copyStatus = document.querySelector<HTMLElement>('[data-invoice-copy-status]');
  const copyLinkStatus = document.querySelector<HTMLElement>('[data-invoice-link-copy-status]');
  const invoiceLogMessage = document.querySelector<HTMLInputElement>('[data-invoice-log-message]');
  const templateButtons = document.querySelectorAll<HTMLButtonElement>('[data-template-button]');

  const templates = templatesElement?.textContent ? (JSON.parse(templatesElement.textContent) as InvoiceTemplate[]) : [];
  const whatsappNumber = whatsappNumberElement?.textContent ? (JSON.parse(whatsappNumberElement.textContent) as string) : '';

  const buildWhatsappUrl = (message: string) => {
    const encodedMessage = encodeURIComponent(message);

    if (!whatsappNumber) {
      return `https://wa.me/?text=${encodedMessage}`;
    }

    return `https://wa.me/${whatsappNumber}?text=${encodedMessage}`;
  };

  const setActiveTemplate = (templateKey: string) => {
    const selectedTemplate = templates.find((template) => template.key === templateKey) ?? templates[0];

    if (!selectedTemplate || !previewElement || !whatsappLink) {
      return;
    }

    previewElement.value = selectedTemplate.message;
    if (invoiceLogMessage) {
      invoiceLogMessage.value = selectedTemplate.message;
    }
    whatsappLink.href = buildWhatsappUrl(selectedTemplate.message);

    templateButtons.forEach((button) => {
      button.dataset.active = String(button.dataset.templateKey === selectedTemplate.key);
    });
  };

  templateButtons.forEach((button) => {
    button.addEventListener('click', () => {
      if (button.dataset.templateKey) {
        setActiveTemplate(button.dataset.templateKey);
      }
    });
  });

  copyButton?.addEventListener('click', async () => {
    const text = previewElement?.value ?? '';

    if (!text) {
      return;
    }

    await navigator.clipboard.writeText(text);
    copyStatus?.classList.remove('hidden');
    window.setTimeout(() => copyStatus?.classList.add('hidden'), 1800);
  });

  copyLinkButton?.addEventListener('click', async () => {
    const invoiceUrl = copyLinkButton.dataset.invoiceUrl ?? '';

    if (!invoiceUrl) {
      return;
    }

    await navigator.clipboard.writeText(invoiceUrl);
    copyLinkStatus?.classList.remove('hidden');
    window.setTimeout(() => copyLinkStatus?.classList.add('hidden'), 1800);
  });

  if (templates[0]) {
    setActiveTemplate(templates[0].key);
  }
</script>
