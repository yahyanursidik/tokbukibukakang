---
import AdminShell from '@/components/AdminShell.astro';
import { isAdminAuthenticated } from '@/lib/admin/auth';
import {
  formatDateTime,
  formatRupiah,
  listAdminPaymentConfirmations,
  statusLabel,
  updatePaymentConfirmationStatus
} from '@/lib/admin/orders';

export const prerender = false;

if (!(await isAdminAuthenticated(Astro.cookies))) {
  return Astro.redirect(`/admin?next=${encodeURIComponent(Astro.url.pathname)}`);
}

let actionMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const id = String(formData.get('id') ?? '');
  const action = String(formData.get('_action') ?? '');

  try {
    if (id && action === 'confirm') {
      await updatePaymentConfirmationStatus(id, 'confirmed');
      actionMessage = 'Pembayaran ditandai confirmed.';
    }

    if (id && action === 'reject') {
      await updatePaymentConfirmationStatus(id, 'rejected');
      actionMessage = 'Pembayaran ditandai rejected.';
    }
  } catch (error) {
    errorMessage = error instanceof Error ? error.message : 'Status pembayaran belum berhasil diperbarui.';
  }
}

let confirmations: Awaited<ReturnType<typeof listAdminPaymentConfirmations>> = [];

try {
  confirmations = await listAdminPaymentConfirmations();
} catch (error) {
  errorMessage = error instanceof Error ? error.message : 'Konfirmasi pembayaran belum dapat dimuat.';
}
---

<AdminShell title="Payments Ibu Kakang" currentPath={Astro.url.pathname}>
  <div class="watercolor-panel p-6 sm:p-8">
    <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Payments</p>
    <h1 class="mt-3 font-serif text-4xl font-bold text-ink">Konfirmasi pembayaran</h1>
  </div>

  {actionMessage && <div class="mt-6 rounded-3xl border border-[#b9d8c2] bg-[#edf7ef] p-4 text-sm font-bold text-[#36543c]">{actionMessage}</div>}
  {errorMessage && <div class="mt-6 rounded-3xl border border-date/25 bg-parchment/80 p-4 text-sm font-bold text-date">{errorMessage}</div>}

  <section class="mt-6 grid gap-4">
    {confirmations.length === 0 ? (
      <div class="soft-card p-8 text-center text-[#70675e]">Belum ada konfirmasi pembayaran.</div>
    ) : confirmations.map((confirmation) => (
      <article class="soft-card grid gap-5 p-5 lg:grid-cols-[1fr_auto] lg:items-start">
        <div>
          <div class="flex flex-wrap items-center gap-2">
            <span class="rounded-full bg-honey px-3 py-1 text-xs font-bold text-date">{statusLabel(confirmation.status)}</span>
            {confirmation.order && <a class="text-sm font-bold text-ink hover:text-date" href={`/admin/orders/${confirmation.order.id}`}>{confirmation.order.order_number}</a>}
          </div>
          <h2 class="mt-3 font-serif text-2xl font-bold text-ink">{confirmation.sender_name}</h2>
          <dl class="mt-3 grid gap-2 text-sm sm:grid-cols-2">
            <div><dt class="font-bold text-date">Bank</dt><dd class="text-[#70675e]">{confirmation.bank_name ?? '-'}</dd></div>
            <div><dt class="font-bold text-date">Amount</dt><dd class="text-[#70675e]">{formatRupiah(confirmation.amount)}</dd></div>
            <div><dt class="font-bold text-date">Transfer date</dt><dd class="text-[#70675e]">{confirmation.transfer_date}</dd></div>
            <div><dt class="font-bold text-date">Submitted</dt><dd class="text-[#70675e]">{formatDateTime(confirmation.created_at)}</dd></div>
            {confirmation.order && <div><dt class="font-bold text-date">Customer</dt><dd class="text-[#70675e]">{confirmation.order.customer_name} - {confirmation.order.customer_phone}</dd></div>}
            {confirmation.customer_note && <div class="sm:col-span-2"><dt class="font-bold text-date">Catatan</dt><dd class="text-[#70675e]">{confirmation.customer_note}</dd></div>}
          </dl>
          {confirmation.proof_url ? (
            <a class="mt-4 inline-flex rounded-full border border-date/25 bg-white/80 px-4 py-2 text-sm font-bold text-date hover:bg-parchment" href={confirmation.proof_url} target="_blank" rel="noreferrer">Lihat bukti transfer</a>
          ) : (
            <p class="mt-4 text-sm font-semibold text-[#70675e]">Tidak ada bukti transfer terunggah.</p>
          )}
        </div>

        <div class="flex flex-wrap gap-2 lg:justify-end">
          <form method="post">
            <input type="hidden" name="id" value={confirmation.id} />
            <input type="hidden" name="_action" value="confirm" />
            <button class="rounded-full bg-[#36543c] px-4 py-2 text-sm font-bold text-white disabled:opacity-50" type="submit" disabled={confirmation.status === 'confirmed'}>
              Confirm
            </button>
          </form>
          <form method="post">
            <input type="hidden" name="id" value={confirmation.id} />
            <input type="hidden" name="_action" value="reject" />
            <button class="rounded-full border border-date/25 bg-white/80 px-4 py-2 text-sm font-bold text-date disabled:opacity-50" type="submit" disabled={confirmation.status === 'rejected'}>
              Reject
            </button>
          </form>
        </div>
      </article>
    ))}
  </section>
</AdminShell>
