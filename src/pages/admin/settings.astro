---
import AdminShell from '@/components/AdminShell.astro';
import { isAdminAuthenticated } from '@/lib/admin/auth';
import { getPaymentSettings, parsePaymentSettingsForm, updatePaymentSettings } from '@/lib/admin/settings';

export const prerender = false;

if (!(await isAdminAuthenticated(Astro.cookies))) {
  return Astro.redirect(`/admin?next=${encodeURIComponent(Astro.url.pathname)}`);
}

let actionMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();

  try {
    await updatePaymentSettings(await parsePaymentSettingsForm(formData));
    actionMessage = 'Pengaturan invoice dan pembayaran berhasil disimpan.';
  } catch (error) {
    errorMessage = error instanceof Error ? error.message : 'Pengaturan belum berhasil disimpan.';
  }
}

let settings: Awaited<ReturnType<typeof getPaymentSettings>> | null = null;

try {
  settings = await getPaymentSettings();
} catch (error) {
  errorMessage = error instanceof Error ? error.message : 'Pengaturan belum dapat dimuat.';
}
---

<AdminShell title="Settings Ibu Kakang" currentPath={Astro.url.pathname}>
  <div class="watercolor-panel p-6 sm:p-8">
    <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Settings</p>
    <h1 class="mt-3 font-serif text-4xl font-bold text-ink">Invoice dan pembayaran</h1>
    <p class="mt-3 max-w-2xl text-[#70675e]">
      Atur rekening, QRIS, dan instruksi konfirmasi yang akan muncul di invoice publik dan template WhatsApp Ibu Kakang.
    </p>
  </div>

  {actionMessage && <div class="mt-6 rounded-3xl border border-[#b9d8c2] bg-[#edf7ef] p-4 text-sm font-bold text-[#36543c]">{actionMessage}</div>}
  {errorMessage && <div class="mt-6 rounded-3xl border border-date/25 bg-parchment/80 p-4 text-sm font-bold text-date">{errorMessage}</div>}

  {settings && (
    <form class="soft-card mt-6 grid gap-5 p-5 sm:p-6" method="post" enctype="multipart/form-data">
      <div class="grid gap-4 md:grid-cols-3">
        <label class="grid gap-2 text-sm font-bold text-[#5f564e]">
          Nama bank
          <input class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name="bank_name" value={settings.bank_name ?? ''} />
        </label>
        <label class="grid gap-2 text-sm font-bold text-[#5f564e]">
          Nomor rekening
          <input class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name="account_number" value={settings.account_number ?? ''} />
        </label>
        <label class="grid gap-2 text-sm font-bold text-[#5f564e]">
          Atas nama
          <input class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name="account_holder" value={settings.account_holder ?? ''} />
        </label>
      </div>

      <div class="grid gap-4 lg:grid-cols-[320px_1fr]">
        <div class="grid gap-3 text-sm font-bold text-[#5f564e]">
          QRIS
          {settings.qris_image_url ? (
            <img class="aspect-square w-full max-w-xs rounded-3xl border border-[#eadcc7] bg-white object-contain p-3 shadow-soft" src={settings.qris_image_url} alt="QRIS pembayaran saat ini" loading="lazy" />
          ) : (
            <div class="grid aspect-square w-full max-w-xs place-items-center rounded-3xl border border-dashed border-date/25 bg-parchment/60 p-4 text-center text-sm text-[#70675e]">
              Belum ada QRIS.
            </div>
          )}
        </div>
        <div class="grid h-fit gap-4">
          <label class="grid gap-2 text-sm font-bold text-[#5f564e]">
            Upload QRIS
            <input class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name="qris_file" type="file" accept="image/jpeg,image/png,image/webp" />
          </label>
          <label class="grid gap-2 text-sm font-bold text-[#5f564e]">
            URL QRIS
            <input class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name="qris_image_url" value={settings.qris_image_url ?? ''} placeholder="Atau tempel URL QRIS" />
          </label>
          <label class="grid gap-2 text-sm font-bold text-[#5f564e]">
            Catatan QRIS
            <textarea class="min-h-24 rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name="qris_note">{settings.qris_note ?? ''}</textarea>
          </label>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <label class="grid gap-2 text-sm font-bold text-[#5f564e]">
          WhatsApp Ibu Kakang
          <input class="rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name="whatsapp_admin_phone" value={settings.whatsapp_admin_phone ?? ''} placeholder="Contoh: 62812..." />
          <span class="text-xs font-medium text-[#82766b]">Ditampilkan di invoice untuk bantuan dan konfirmasi manual.</span>
        </label>
        <label class="grid gap-2 text-sm font-bold text-[#5f564e]">
          Catatan konfirmasi pembayaran
          <textarea class="min-h-32 rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name="payment_confirmation_notes">{settings.payment_confirmation_notes ?? ''}</textarea>
        </label>
      </div>

      <label class="grid gap-2 text-sm font-bold text-[#5f564e]">
        Footer invoice
        <textarea class="min-h-28 rounded-3xl border border-[#eadcc7] bg-white/80 px-4 py-3 font-normal text-ink outline-none focus:border-date focus:ring-4 focus:ring-honey/30" name="invoice_footer">{settings.invoice_footer ?? ''}</textarea>
      </label>

      <div>
        <button class="rounded-full bg-ink px-6 py-3 text-sm font-bold text-cream transition hover:-translate-y-0.5 hover:bg-date" type="submit">
          Simpan pengaturan
        </button>
      </div>
    </form>
  )}
</AdminShell>
