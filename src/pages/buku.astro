---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { placeholderPages } from '@/config/site';
import { listPublicBooks } from '@/lib/content/public';

export const prerender = false;

const page = placeholderPages.books;
const books = await listPublicBooks();

const categories = [...new Set(books.flatMap((book) => book.categories))].sort((a, b) => a.localeCompare(b, 'id-ID'));
const themes = [...new Set(books.flatMap((book) => book.themes))].sort((a, b) => a.localeCompare(b, 'id-ID'));

const ageRanges = [
  { label: 'Semua usia', value: 'all' },
  { label: '0-4 tahun', value: '0-4' },
  { label: '5-7 tahun', value: '5-7' },
  { label: '8-10 tahun', value: '8-10' },
  { label: '11+ tahun', value: '11-99' }
];

const formatPrice = new Intl.NumberFormat('id-ID', {
  style: 'currency',
  currency: 'IDR',
  maximumFractionDigits: 0
});
---

<BaseLayout title="Buku" description={page.description}>
  <section class="page-shell py-10 sm:py-14">
    <div class="watercolor-panel p-6 sm:p-8 lg:p-10">
      <div class="grid gap-7 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <p class="mb-4 inline-flex rounded-full border border-date/20 bg-white/60 px-4 py-2 text-xs font-bold uppercase tracking-[0.14em] text-date">
            Katalog buku
          </p>
          <h1 class="max-w-3xl font-serif text-4xl font-bold leading-tight text-ink sm:text-5xl">
            Pilih bacaan anak Islami yang sesuai usia dan kebutuhan keluarga.
          </h1>
          <p class="mt-5 max-w-2xl text-base text-[#5f564e] sm:text-lg">
            Cari buku berdasarkan judul, rentang usia, kategori, tema, dan jenis stok. Pilihan bisa langsung masuk keranjang lokal sebelum checkout manual.
          </p>
        </div>
        <div class="catalog-motif" aria-hidden="true">
          <span class="catalog-motif-book"></span>
          <span class="catalog-motif-paper"></span>
          <span class="catalog-motif-leaf"></span>
        </div>
      </div>
    </div>

    <section class="mt-8 grid gap-5 lg:grid-cols-[280px_1fr]">
      <aside class="soft-card h-fit p-5 lg:sticky lg:top-28">
        <div class="mb-5 flex items-center justify-between gap-3">
          <h2 class="font-serif text-2xl font-bold text-ink">Filter</h2>
          <button class="text-sm font-bold text-date hover:text-ink" type="button" data-reset-filters>
            Reset
          </button>
        </div>

        <form class="grid gap-4" data-catalog-filters>
          <label class="grid gap-2">
            <span class="text-sm font-bold text-[#5f564e]">Cari judul</span>
            <input
              class="rounded-2xl border border-date/20 bg-white/75 px-4 py-3 text-sm text-ink outline-none transition placeholder:text-[#9a9086] focus:border-date focus:ring-4 focus:ring-honey/25"
              type="search"
              name="search"
              placeholder="Contoh: adab, doa, jurnal"
              data-filter-search
            />
          </label>

          <label class="grid gap-2">
            <span class="text-sm font-bold text-[#5f564e]">Rentang usia</span>
            <select class="catalog-select" name="age" data-filter-age>
              {ageRanges.map((range) => <option value={range.value}>{range.label}</option>)}
            </select>
          </label>

          <label class="grid gap-2">
            <span class="text-sm font-bold text-[#5f564e]">Kategori</span>
            <select class="catalog-select" name="category" data-filter-category>
              <option value="all">Semua kategori</option>
              {categories.map((category) => <option value={category}>{category}</option>)}
            </select>
          </label>

          <label class="grid gap-2">
            <span class="text-sm font-bold text-[#5f564e]">Tema</span>
            <select class="catalog-select" name="theme" data-filter-theme>
              <option value="all">Semua tema</option>
              {themes.map((theme) => <option value={theme}>{theme}</option>)}
            </select>
          </label>

          <fieldset class="grid gap-2">
            <legend class="text-sm font-bold text-[#5f564e]">Jenis stok</legend>
            <div class="grid grid-cols-2 gap-2 lg:grid-cols-1">
              <label class="catalog-radio">
                <input type="radio" name="stock" value="all" checked data-filter-stock />
                <span>Semua</span>
              </label>
              <label class="catalog-radio">
                <input type="radio" name="stock" value="preorder" data-filter-stock />
                <span>Pre-order</span>
              </label>
              <label class="catalog-radio">
                <input type="radio" name="stock" value="ready_stock" data-filter-stock />
                <span>Ready stock</span>
              </label>
            </div>
          </fieldset>
        </form>
      </aside>

      <section>
        <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
          <div>
            <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Hasil katalog</p>
            <h2 class="font-serif text-3xl font-bold text-ink">Buku aktif</h2>
          </div>
          <p class="text-sm font-semibold text-[#70675e]" aria-live="polite">
            <span data-result-count>{books.length}</span> buku ditemukan
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3" data-book-grid>
          {
            books.map((book) => (
              <article
                class="book-card soft-card flex min-h-full flex-col overflow-hidden"
                data-book-card
                data-title={book.title.toLocaleLowerCase('id-ID')}
                data-age-min={book.ageMin}
                data-age-max={book.ageMax}
                data-categories={book.categories.join('|').toLocaleLowerCase('id-ID')}
                data-themes={book.themes.join('|').toLocaleLowerCase('id-ID')}
                data-stock={book.stockType}
              >
                <a class="relative block aspect-[4/3] overflow-hidden bg-parchment" href={`/buku/${book.slug}`} aria-label={`Lihat detail ${book.title}`}>
                  <img
                    class="h-full w-full object-cover transition duration-300 hover:scale-[1.03]"
                    src={book.coverImage}
                    alt={`Sampul ${book.title}`}
                    loading="lazy"
                  />
                  <span class="absolute left-4 top-4 rounded-full bg-white/85 px-3 py-1 text-xs font-bold text-date shadow-soft">
                    Usia {book.ageMin}-{book.ageMax}
                  </span>
                  <span class={`absolute right-4 top-4 rounded-full px-3 py-1 text-xs font-bold shadow-soft ${book.stockType === 'preorder' ? 'bg-honey text-date' : 'bg-mint text-[#36543c]'}`}>
                    {book.stockType === 'preorder' ? 'Pre-order' : 'Ready stock'}
                  </span>
                </a>

                <div class="flex flex-1 flex-col p-5">
                  <div class="mb-3 flex flex-wrap gap-2">
                    {book.themes.slice(0, 3).map((theme) => (
                      <span class="rounded-full border border-date/15 bg-white/60 px-3 py-1 text-xs font-semibold text-[#5f564e]">
                        {theme}
                      </span>
                    ))}
                  </div>
                  <h3 class="font-serif text-xl font-bold leading-tight text-ink">
                    <a class="hover:text-date" href={`/buku/${book.slug}`}>{book.title}</a>
                  </h3>
                  {book.subtitle && <p class="mt-1 text-sm font-semibold text-date">{book.subtitle}</p>}
                  <p class="mt-3 text-sm text-[#70675e]">{book.reviewSummary || book.shortDescription}</p>
                  <div class="mt-4 flex flex-wrap gap-2">
                    {book.categories.map((category) => (
                      <span class="rounded-full bg-parchment/80 px-3 py-1 text-xs font-bold text-date">{category}</span>
                    ))}
                  </div>
                  <div class="mt-auto pt-5">
                    <p class="mb-4 font-serif text-2xl font-bold text-ink">{formatPrice.format(book.price)}</p>
                    <div class="grid gap-2 sm:grid-cols-2">
                      <a class="button-secondary" href={`/resensi?book=${book.slug}`}>
                        Lihat Resensi
                      </a>
                      <button
                        class="button-primary"
                        type="button"
                        data-cart-button
                        data-book-slug={book.slug}
                        data-book-title={book.title}
                        data-book-price={book.price}
                        data-book-cover-image={book.coverImage}
                        data-book-stock-type={book.stockType}
                      >
                        Masukkan Keranjang
                      </button>
                    </div>
                  </div>
                </div>
              </article>
            ))
          }
        </div>

        <div class="empty-state mt-4 hidden" data-empty-state>
          <div class="motif motif-book mx-auto mb-5 scale-75" aria-hidden="true"></div>
          <h3 class="font-serif text-2xl font-bold text-ink">Belum ada buku yang cocok.</h3>
          <p class="mx-auto mt-3 max-w-md text-sm text-[#70675e]">
            Coba ringankan kata pencarian atau pilih filter yang lebih umum.
          </p>
        </div>
      </section>
    </section>
  </section>
</BaseLayout>

<script>
  import { addToCart, type CartItemInput } from '@/lib/cart';

  const normalize = (value: string) => value.toLocaleLowerCase('id-ID').trim();
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-book-card]'));
  const resultCount = document.querySelector('[data-result-count]');
  const emptyState = document.querySelector('[data-empty-state]');
  const searchInput = document.querySelector<HTMLInputElement>('[data-filter-search]');
  const ageSelect = document.querySelector<HTMLSelectElement>('[data-filter-age]');
  const categorySelect = document.querySelector<HTMLSelectElement>('[data-filter-category]');
  const themeSelect = document.querySelector<HTMLSelectElement>('[data-filter-theme]');
  const stockInputs = Array.from(document.querySelectorAll<HTMLInputElement>('[data-filter-stock]'));
  const resetButton = document.querySelector('[data-reset-filters]');

  const getSelectedStock = () => {
    const selected = stockInputs.find((input) => input.checked);
    return selected?.value || 'all';
  };

  const overlapsAgeRange = (card: HTMLElement, ageValue: string) => {
    if (ageValue === 'all') {
      return true;
    }

    const [filterMin, filterMax] = ageValue.split('-').map(Number);
    const ageMin = Number(card.dataset.ageMin);
    const ageMax = Number(card.dataset.ageMax);

    return ageMin <= filterMax && ageMax >= filterMin;
  };

  const applyFilters = () => {
    if (!searchInput || !ageSelect || !categorySelect || !themeSelect || !resultCount || !emptyState) {
      return;
    }

    const search = normalize(searchInput.value);
    const age = ageSelect.value;
    const category = normalize(categorySelect.value);
    const theme = normalize(themeSelect.value);
    const stock = getSelectedStock();
    let visibleCount = 0;

    cards.forEach((card) => {
      const matchesSearch = !search || (card.dataset.title ?? '').includes(search);
      const matchesAge = overlapsAgeRange(card, age);
      const matchesCategory = category === 'all' || (card.dataset.categories ?? '').split('|').includes(category);
      const matchesTheme = theme === 'all' || (card.dataset.themes ?? '').split('|').includes(theme);
      const matchesStock = stock === 'all' || card.dataset.stock === stock;
      const isVisible = matchesSearch && matchesAge && matchesCategory && matchesTheme && matchesStock;

      card.toggleAttribute('hidden', !isVisible);
      if (isVisible) {
        visibleCount += 1;
      }
    });

    resultCount.textContent = String(visibleCount);
    emptyState.classList.toggle('hidden', visibleCount > 0);
  };

  searchInput?.addEventListener('input', applyFilters);
  ageSelect?.addEventListener('change', applyFilters);
  categorySelect?.addEventListener('change', applyFilters);
  themeSelect?.addEventListener('change', applyFilters);
  stockInputs.forEach((input) => input.addEventListener('change', applyFilters));

  resetButton?.addEventListener('click', () => {
    if (!searchInput || !ageSelect || !categorySelect || !themeSelect) {
      return;
    }

    searchInput.value = '';
    ageSelect.value = 'all';
    categorySelect.value = 'all';
    themeSelect.value = 'all';
    stockInputs.forEach((input) => {
      input.checked = input.value === 'all';
    });
    applyFilters();
  });

  const getCartItemFromButton = (button: HTMLButtonElement): CartItemInput | null => {
    const { bookSlug, bookTitle, bookPrice, bookCoverImage, bookStockType } = button.dataset;
    const price = Number(bookPrice);

    if (
      !bookSlug ||
      !bookTitle ||
      !bookCoverImage ||
      (bookStockType !== 'preorder' && bookStockType !== 'ready_stock') ||
      !Number.isFinite(price)
    ) {
      return null;
    }

    return {
      slug: bookSlug,
      title: bookTitle,
      price,
      coverImage: bookCoverImage,
      stockType: bookStockType
    };
  };

  document.querySelectorAll<HTMLButtonElement>('[data-cart-button]').forEach((button) => {
    button.addEventListener('click', () => {
      const cartItem = getCartItemFromButton(button);

      if (!cartItem) {
        return;
      }

      addToCart(cartItem);
      button.textContent = 'Sudah masuk';
      button.setAttribute('aria-live', 'polite');
      window.setTimeout(() => {
        button.textContent = 'Masukkan Keranjang';
      }, 1400);
    });
  });
</script>

<style>
  .catalog-select {
    width: 100%;
    border: 1px solid rgba(138, 95, 63, 0.2);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.75);
    color: #2f2a25;
    font-size: 0.875rem;
    outline: none;
    padding: 0.75rem 1rem;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .catalog-select:focus {
    border-color: #8a5f3f;
    box-shadow: 0 0 0 4px rgba(242, 202, 126, 0.25);
  }

  .catalog-radio {
    align-items: center;
    border: 1px solid rgba(138, 95, 63, 0.18);
    border-radius: 1rem;
    cursor: pointer;
    display: flex;
    gap: 0.65rem;
    min-height: 44px;
    padding: 0.7rem 0.85rem;
  }

  .catalog-radio input {
    accent-color: #8a5f3f;
  }

  .catalog-radio span {
    color: #5f564e;
    font-size: 0.875rem;
    font-weight: 700;
  }

  .catalog-motif {
    height: 170px;
    position: relative;
    width: min(260px, 100%);
  }

  .catalog-motif-book,
  .catalog-motif-paper,
  .catalog-motif-leaf {
    position: absolute;
  }

  .catalog-motif-book {
    bottom: 16px;
    left: 30px;
    height: 110px;
    width: 76px;
    border: 2px solid rgba(138, 95, 63, 0.62);
    border-radius: 14px 8px 8px 14px;
    background: #b8dce8;
    box-shadow:
      54px 0 0 #f2ca7e,
      inset 0 18px 0 rgba(255, 255, 255, 0.28);
  }

  .catalog-motif-paper {
    right: 20px;
    top: 18px;
    height: 82px;
    width: 100px;
    border: 2px solid rgba(138, 95, 63, 0.48);
    border-radius: 18px;
    background: rgba(255, 250, 241, 0.88);
    transform: rotate(8deg);
  }

  .catalog-motif-leaf {
    bottom: 4px;
    right: 38px;
    height: 48px;
    width: 76px;
    border: 2px solid rgba(109, 143, 112, 0.62);
    border-radius: 70% 18% 70% 18%;
    background: rgba(185, 216, 194, 0.78);
    transform: rotate(-22deg);
  }

  .book-card[hidden] {
    display: none;
  }
</style>
