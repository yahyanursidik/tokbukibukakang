---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublicBookBySlug, listPublicBooks, listPublicPoPeriods } from '@/lib/content/public';
import { formatRupiah, getSavingsAmount, getSavingsPercent, hasDiscountPrice } from '@/lib/pricing';

export const prerender = false;

const data = await getPublicBookBySlug(Astro.params.slug ?? '');

if (!data) {
  return new Response(null, { status: 404 });
}

const productImages = [data.coverImage, ...(data.galleryImages ?? [])].filter(
  (imageUrl, index, images) => imageUrl && images.indexOf(imageUrl) === index
);
const allBooks = await listPublicBooks();
const poPeriods = await listPublicPoPeriods();

const activePoPeriods = poPeriods
  .filter((period) => period.status === 'open' && period.bookSlugs.includes(data.slug))
  .sort((a, b) => a.endDate.getTime() - b.endDate.getTime());

const relatedBooks = allBooks
  .filter((entry) => entry.slug !== data.slug)
  .map((entry) => {
    const categoryScore = entry.categories.filter((category) => data.categories.includes(category)).length;
    const themeScore = entry.themes.filter((theme) => data.themes.includes(theme)).length;

    return {
      entry,
      score: categoryScore * 2 + themeScore
    };
  })
  .sort((a, b) => b.score - a.score || Number(b.entry.featured) - Number(a.entry.featured))
  .slice(0, 3)
  .map((item) => item.entry);

const formatDate = new Intl.DateTimeFormat('id-ID', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
---

<BaseLayout title={data.title} description={data.shortDescription}>
  <section class="page-shell py-10 sm:py-14">
    <a class="mb-6 inline-flex text-sm font-bold text-date hover:text-ink" href="/buku">
      Kembali ke katalog
    </a>

    <article class="watercolor-panel overflow-hidden">
      <div class="grid gap-0 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="relative bg-parchment p-6 sm:p-8">
          <img
            data-product-gallery-main
            class="mx-auto aspect-[3/4] w-full max-w-sm rounded-[28px] border border-date/20 bg-white/70 object-contain p-4 shadow-soft"
            src={data.coverImage}
            alt={`Sampul ${data.title}`}
          />
          {productImages.length > 1 && (
            <div class="mt-4 grid grid-cols-4 gap-2 sm:grid-cols-5" data-product-gallery>
              {productImages.map((imageUrl, index) => (
                <button
                  class="aspect-[4/3] overflow-hidden rounded-2xl border border-date/20 bg-white/70 p-1 transition hover:border-date"
                  type="button"
                  data-gallery-image={imageUrl}
                  data-gallery-alt={`${index === 0 ? 'Sampul' : 'Foto produk'} ${data.title}`}
                  aria-label={`Lihat gambar ${index + 1} ${data.title}`}
                >
                  <img class="h-full w-full rounded-xl object-contain" src={imageUrl} alt="" loading={index === 0 ? 'eager' : 'lazy'} />
                </button>
              ))}
            </div>
          )}
        </div>

        <div class="p-6 sm:p-8 lg:p-10">
          <div class="flex flex-wrap gap-2">
            <span class={`rounded-full px-3 py-1 text-xs font-bold ${data.stockType === 'preorder' ? 'bg-honey text-date' : 'bg-mint text-[#36543c]'}`}>
              {data.stockType === 'preorder' ? 'Pre-order' : 'Ready stock'}
            </span>
            {data.featured && <span class="rounded-full bg-white/72 px-3 py-1 text-xs font-bold text-date">Pilihan Books by Ibunya Kakang</span>}
          </div>

          <h1 class="mt-5 font-serif text-4xl font-bold leading-tight text-ink sm:text-5xl">{data.title}</h1>
          {data.subtitle && <p class="mt-3 text-lg font-semibold text-date">{data.subtitle}</p>}

          <dl class="mt-6 grid gap-4 text-sm sm:grid-cols-2">
            {data.author && (
              <div class="rounded-2xl bg-white/62 p-4">
                <dt class="font-bold text-date">Penulis</dt>
                <dd class="mt-1 text-[#5f564e]">{data.author}</dd>
              </div>
            )}
            {data.publisher && (
              <div class="rounded-2xl bg-white/62 p-4">
                <dt class="font-bold text-date">Penerbit</dt>
                <dd class="mt-1 text-[#5f564e]">{data.publisher}</dd>
              </div>
            )}
            <div class="rounded-2xl bg-white/62 p-4">
              <dt class="font-bold text-date">Rekomendasi usia</dt>
              <dd class="mt-1 text-[#5f564e]">{data.ageMin}-{data.ageMax} tahun</dd>
            </div>
          </dl>

          <section class="mt-6 rounded-3xl border border-date/15 bg-white/72 p-5">
            <p class="text-xs font-bold uppercase tracking-[0.14em] text-date">{data.stockType === 'preorder' ? 'Harga PO' : 'Harga jual'}</p>
            {hasDiscountPrice(data) && (
              <div class="mt-3 flex flex-wrap items-center gap-2">
                <span class="text-base font-semibold text-[#8d8278] line-through">{formatRupiah(data.originalPrice!)}</span>
                <span class="rounded-full bg-honey/70 px-3 py-1 text-xs font-bold text-date">Hemat {getSavingsPercent(data)}%</span>
              </div>
            )}
            <p class="mt-1 font-serif text-4xl font-bold text-ink">{formatRupiah(data.price)}</p>
            {hasDiscountPrice(data) && <p class="mt-2 text-sm font-semibold text-[#70675e]">Lebih hemat {formatRupiah(getSavingsAmount(data))} dari harga asli.</p>}
          </section>

          <div class="mt-6 grid gap-4">
            <div>
              <h2 class="text-sm font-bold uppercase tracking-[0.14em] text-date">Kategori</h2>
              <div class="mt-3 flex flex-wrap gap-2">
                {data.categories.map((category) => <span class="rounded-full bg-white/70 px-3 py-1 text-xs font-bold text-[#5f564e]">{category}</span>)}
              </div>
            </div>
            <div>
              <h2 class="text-sm font-bold uppercase tracking-[0.14em] text-date">Tema</h2>
              <div class="mt-3 flex flex-wrap gap-2">
                {data.themes.map((theme) => <span class="rounded-full border border-date/15 bg-parchment/70 px-3 py-1 text-xs font-bold text-date">{theme}</span>)}
              </div>
            </div>
          </div>

          <button
            class="button-primary mt-8 w-full sm:w-auto"
            type="button"
            data-cart-button
            data-book-slug={data.slug}
            data-book-title={data.title}
            data-book-price={data.price}
            data-book-cover-image={data.coverImage}
            data-book-stock-type={data.stockType}
          >
            Masukkan Keranjang
          </button>
        </div>
      </div>
    </article>

    {
      activePoPeriods.length > 0 && (
        <section class="mt-8 soft-card p-6 sm:p-8">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Tersedia dalam PO aktif</p>
          <div class="mt-4 grid gap-4 md:grid-cols-2">
            {activePoPeriods.map((period) => (
              <article class="rounded-3xl border border-date/15 bg-white/62 p-5">
                <h2 class="font-serif text-2xl font-bold text-ink">{period.title}</h2>
                <p class="mt-2 text-sm text-[#70675e]">{period.description}</p>
                <dl class="mt-4 grid gap-3 text-sm sm:grid-cols-2">
                  <div>
                    <dt class="font-bold text-date">Tutup PO</dt>
                    <dd class="text-[#5f564e]">{formatDate.format(period.endDate)}</dd>
                  </div>
                  <div>
                    <dt class="font-bold text-date">Estimasi kirim</dt>
                    <dd class="text-[#5f564e]">{formatDate.format(period.estimatedShippingDate)}</dd>
                  </div>
                </dl>
                <a class="button-primary mt-5 bg-date hover:bg-ink" href={`/po/${period.slug}`}>
                  Lihat detail PO
                </a>
              </article>
            ))}
          </div>
        </section>
      )
    }

    <section class="mt-8 grid gap-4 lg:grid-cols-[1fr_0.9fr]">
      <div class="grid gap-4">
        <article class="soft-card p-6 sm:p-8">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Deskripsi singkat</p>
          <p class="mt-4 text-[#5f564e] sm:text-lg">{data.shortDescription}</p>
        </article>

        <article class="soft-card p-6 sm:p-8">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Ringkasan resensi</p>
          <p class="mt-4 text-[#5f564e] sm:text-lg">{data.reviewSummary}</p>
        </article>

        <article class="soft-card p-6 sm:p-8">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Catatan untuk orang tua</p>
          <p class="mt-4 text-[#5f564e] sm:text-lg">{data.parentNotes}</p>
        </article>
      </div>

      <aside class="grid gap-4">
        <article class="soft-card p-6 sm:p-8">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Catatan kurasi Books by Ibunya Kakang</p>
          <p class="mt-4 text-[#5f564e]">
            Buku ini diposisikan sebagai bacaan keluarga yang dapat dibaca perlahan, ditemani percakapan, dan disesuaikan dengan kesiapan anak.
          </p>
        </article>

        {data.manhajNotes && (
          <article class="soft-card p-6 sm:p-8">
            <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Catatan kesesuaian manhaj</p>
            <p class="mt-4 text-[#5f564e]">{data.manhajNotes}</p>
          </article>
        )}

        {data.externalReviewSources && data.externalReviewSources.length > 0 && (
          <article class="soft-card p-6 sm:p-8">
            <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Sumber resensi eksternal</p>
            <p class="mt-4 text-sm text-[#70675e]">
              Sumber berikut hanya dijadikan rujukan ringkas. Isi resensi tidak disalin penuh.
            </p>
            <ul class="mt-4 grid gap-3">
              {data.externalReviewSources.map((source) => (
                <li class="rounded-2xl bg-white/62 p-4 text-sm">
                  {source.sourceUrl ? (
                    <a class="font-bold text-date hover:text-ink" href={source.sourceUrl} rel="noreferrer" target="_blank">
                      {source.sourceName}
                    </a>
                  ) : (
                    <span class="font-bold text-date">{source.sourceName}</span>
                  )}
                </li>
              ))}
            </ul>
          </article>
        )}
      </aside>
    </section>

    <section class="mt-10">
      <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Buku terkait</p>
          <h2 class="font-serif text-3xl font-bold text-ink">Pilihan lain yang masih satu suasana</h2>
        </div>
        <a class="text-sm font-bold text-date hover:text-ink" href="/buku">Lihat katalog</a>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {
          relatedBooks.length > 0 ? (
            relatedBooks.map((related) => (
              <article class="soft-card overflow-hidden">
                <div class="grid aspect-[3/4] place-items-center bg-parchment/80 p-4">
                  <img class="h-full w-full object-contain" src={related.coverImage} alt={`Sampul ${related.title}`} loading="lazy" />
                </div>
                <div class="p-5">
                  <p class="text-xs font-bold uppercase tracking-[0.14em] text-date">Usia {related.ageMin}-{related.ageMax}</p>
                  <h3 class="mt-2 font-serif text-xl font-bold leading-tight text-ink">{related.title}</h3>
                  <p class="mt-3 text-sm leading-6 text-[#70675e]">{related.shortDescription}</p>
                  <p class="mt-4 font-serif text-xl font-bold text-ink">{formatRupiah(related.price)}</p>
                  <a class="button-secondary mt-5" href={`/buku/${related.slug}`}>
                    Lihat detail
                  </a>
                </div>
              </article>
            ))
          ) : (
            <p class="empty-state text-sm text-[#70675e] md:col-span-3">
              Belum ada buku terkait yang cocok dari kategori atau tema yang sama.
            </p>
          )
        }
      </div>
    </section>
  </section>
</BaseLayout>

<script>
  import { addToCart, type CartItemInput } from '@/lib/cart';

  const cartButton = document.querySelector<HTMLButtonElement>('[data-cart-button]');
  const galleryMain = document.querySelector<HTMLImageElement>('[data-product-gallery-main]');

  document.querySelectorAll<HTMLButtonElement>('[data-gallery-image]').forEach((button) => {
    button.addEventListener('click', () => {
      if (!galleryMain || !button.dataset.galleryImage) {
        return;
      }

      galleryMain.src = button.dataset.galleryImage;
      galleryMain.alt = button.dataset.galleryAlt || galleryMain.alt;
    });
  });

  const getCartItemFromButton = (button: HTMLButtonElement): CartItemInput | null => {
    const { bookSlug, bookTitle, bookPrice, bookCoverImage, bookStockType } = button.dataset;
    const price = Number(bookPrice);

    if (
      !bookSlug ||
      !bookTitle ||
      !bookCoverImage ||
      (bookStockType !== 'preorder' && bookStockType !== 'ready_stock') ||
      !Number.isFinite(price)
    ) {
      return null;
    }

    return {
      slug: bookSlug,
      title: bookTitle,
      price,
      coverImage: bookCoverImage,
      stockType: bookStockType
    };
  };

  cartButton?.addEventListener('click', () => {
    const cartItem = getCartItemFromButton(cartButton);

    if (!cartItem) {
      return;
    }

    addToCart(cartItem);
    cartButton.textContent = 'Sudah masuk';
    cartButton.setAttribute('aria-live', 'polite');
    window.setTimeout(() => {
      cartButton.textContent = 'Masukkan Keranjang';
    }, 1400);
  });
</script>
