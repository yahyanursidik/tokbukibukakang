---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const books = await getCollection('books');

  return books
    .filter((book) => book.data.isActive)
    .map((book) => ({
      params: { slug: book.data.slug },
      props: { book }
    }));
}

const { book } = Astro.props;
const { data } = book;
const allBooks = (await getCollection('books')).filter((entry) => entry.data.isActive);
const poPeriods = await getCollection('poPeriods');

const activePoPeriods = poPeriods
  .filter((period) => period.data.status === 'open' && period.data.bookSlugs.includes(data.slug))
  .sort((a, b) => a.data.endDate.getTime() - b.data.endDate.getTime());

const relatedBooks = allBooks
  .filter((entry) => entry.data.slug !== data.slug)
  .map((entry) => {
    const categoryScore = entry.data.categories.filter((category) => data.categories.includes(category)).length;
    const themeScore = entry.data.themes.filter((theme) => data.themes.includes(theme)).length;

    return {
      entry,
      score: categoryScore * 2 + themeScore
    };
  })
  .sort((a, b) => b.score - a.score || Number(b.entry.data.featured) - Number(a.entry.data.featured))
  .slice(0, 3)
  .map((item) => item.entry);

const formatPrice = new Intl.NumberFormat('id-ID', {
  style: 'currency',
  currency: 'IDR',
  maximumFractionDigits: 0
});

const formatDate = new Intl.DateTimeFormat('id-ID', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
---

<BaseLayout title={data.title} description={data.shortDescription}>
  <section class="page-shell py-10 sm:py-14">
    <a class="mb-6 inline-flex text-sm font-bold text-date hover:text-ink" href="/buku">
      Kembali ke katalog
    </a>

    <article class="watercolor-panel overflow-hidden">
      <div class="grid gap-0 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="relative bg-parchment p-6 sm:p-8">
          <img
            class="mx-auto aspect-[4/3] w-full max-w-xl rounded-[28px] border border-date/20 object-cover shadow-soft"
            src={data.coverImage}
            alt={`Sampul ${data.title}`}
          />
        </div>

        <div class="p-6 sm:p-8 lg:p-10">
          <div class="flex flex-wrap gap-2">
            <span class={`rounded-full px-3 py-1 text-xs font-bold ${data.stockType === 'preorder' ? 'bg-honey text-date' : 'bg-mint text-[#36543c]'}`}>
              {data.stockType === 'preorder' ? 'Pre-order' : 'Ready stock'}
            </span>
            {data.featured && <span class="rounded-full bg-white/72 px-3 py-1 text-xs font-bold text-date">Pilihan Ibu Kakang</span>}
          </div>

          <h1 class="mt-5 font-serif text-4xl font-bold leading-tight text-ink sm:text-5xl">{data.title}</h1>
          {data.subtitle && <p class="mt-3 text-lg font-semibold text-date">{data.subtitle}</p>}

          <dl class="mt-6 grid gap-4 text-sm sm:grid-cols-2">
            {data.author && (
              <div class="rounded-2xl bg-white/62 p-4">
                <dt class="font-bold text-date">Penulis</dt>
                <dd class="mt-1 text-[#5f564e]">{data.author}</dd>
              </div>
            )}
            {data.publisher && (
              <div class="rounded-2xl bg-white/62 p-4">
                <dt class="font-bold text-date">Penerbit</dt>
                <dd class="mt-1 text-[#5f564e]">{data.publisher}</dd>
              </div>
            )}
            <div class="rounded-2xl bg-white/62 p-4">
              <dt class="font-bold text-date">Rekomendasi usia</dt>
              <dd class="mt-1 text-[#5f564e]">{data.ageMin}-{data.ageMax} tahun</dd>
            </div>
            <div class="rounded-2xl bg-white/62 p-4">
              <dt class="font-bold text-date">Harga</dt>
              <dd class="mt-1 font-serif text-2xl font-bold text-ink">{formatPrice.format(data.price)}</dd>
            </div>
          </dl>

          <div class="mt-6 grid gap-4">
            <div>
              <h2 class="text-sm font-bold uppercase tracking-[0.14em] text-date">Kategori</h2>
              <div class="mt-3 flex flex-wrap gap-2">
                {data.categories.map((category) => <span class="rounded-full bg-white/70 px-3 py-1 text-xs font-bold text-[#5f564e]">{category}</span>)}
              </div>
            </div>
            <div>
              <h2 class="text-sm font-bold uppercase tracking-[0.14em] text-date">Tema</h2>
              <div class="mt-3 flex flex-wrap gap-2">
                {data.themes.map((theme) => <span class="rounded-full border border-date/15 bg-parchment/70 px-3 py-1 text-xs font-bold text-date">{theme}</span>)}
              </div>
            </div>
          </div>

          <button
            class="mt-8 inline-flex w-full items-center justify-center rounded-full bg-ink px-6 py-3 text-sm font-bold text-cream transition hover:-translate-y-0.5 hover:bg-date sm:w-auto"
            type="button"
            data-cart-button
            data-book-slug={data.slug}
            data-book-title={data.title}
            data-book-price={data.price}
            data-book-cover-image={data.coverImage}
            data-book-stock-type={data.stockType}
          >
            Masukkan Keranjang
          </button>
        </div>
      </div>
    </article>

    {
      activePoPeriods.length > 0 && (
        <section class="mt-8 soft-card p-6 sm:p-8">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Tersedia dalam PO aktif</p>
          <div class="mt-4 grid gap-4 md:grid-cols-2">
            {activePoPeriods.map((period) => (
              <article class="rounded-3xl border border-date/15 bg-white/62 p-5">
                <h2 class="font-serif text-2xl font-bold text-ink">{period.data.title}</h2>
                <p class="mt-2 text-sm text-[#70675e]">{period.data.description}</p>
                <dl class="mt-4 grid gap-3 text-sm sm:grid-cols-2">
                  <div>
                    <dt class="font-bold text-date">Tutup PO</dt>
                    <dd class="text-[#5f564e]">{formatDate.format(period.data.endDate)}</dd>
                  </div>
                  <div>
                    <dt class="font-bold text-date">Estimasi kirim</dt>
                    <dd class="text-[#5f564e]">{formatDate.format(period.data.estimatedShippingDate)}</dd>
                  </div>
                </dl>
                <a class="mt-5 inline-flex rounded-full bg-date px-5 py-2 text-sm font-bold text-cream transition hover:-translate-y-0.5 hover:bg-ink" href={`/po/${period.data.slug}`}>
                  Lihat detail PO
                </a>
              </article>
            ))}
          </div>
        </section>
      )
    }

    <section class="mt-8 grid gap-4 lg:grid-cols-[1fr_0.9fr]">
      <div class="grid gap-4">
        <article class="soft-card p-6 sm:p-8">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Deskripsi singkat</p>
          <p class="mt-4 text-[#5f564e] sm:text-lg">{data.shortDescription}</p>
        </article>

        <article class="soft-card p-6 sm:p-8">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Ringkasan resensi</p>
          <p class="mt-4 text-[#5f564e] sm:text-lg">{data.reviewSummary}</p>
        </article>

        <article class="soft-card p-6 sm:p-8">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Catatan untuk orang tua</p>
          <p class="mt-4 text-[#5f564e] sm:text-lg">{data.parentNotes}</p>
        </article>
      </div>

      <aside class="grid gap-4">
        <article class="soft-card p-6 sm:p-8">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Catatan kurasi Ibu Kakang</p>
          <p class="mt-4 text-[#5f564e]">
            Buku ini diposisikan sebagai bacaan keluarga yang dapat dibaca perlahan, ditemani percakapan, dan disesuaikan dengan kesiapan anak.
          </p>
        </article>

        {data.manhajNotes && (
          <article class="soft-card p-6 sm:p-8">
            <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Catatan manhaj</p>
            <p class="mt-4 text-[#5f564e]">{data.manhajNotes}</p>
          </article>
        )}

        {data.externalReviewSources && data.externalReviewSources.length > 0 && (
          <article class="soft-card p-6 sm:p-8">
            <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Sumber resensi eksternal</p>
            <p class="mt-4 text-sm text-[#70675e]">
              Sumber berikut hanya dijadikan rujukan ringkas. Isi resensi tidak disalin penuh.
            </p>
            <ul class="mt-4 grid gap-3">
              {data.externalReviewSources.map((source) => (
                <li class="rounded-2xl bg-white/62 p-4 text-sm">
                  {source.sourceUrl ? (
                    <a class="font-bold text-date hover:text-ink" href={source.sourceUrl} rel="noreferrer" target="_blank">
                      {source.sourceName}
                    </a>
                  ) : (
                    <span class="font-bold text-date">{source.sourceName}</span>
                  )}
                </li>
              ))}
            </ul>
          </article>
        )}
      </aside>
    </section>

    <section class="mt-10">
      <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Buku terkait</p>
          <h2 class="font-serif text-3xl font-bold text-ink">Pilihan lain yang masih satu suasana</h2>
        </div>
        <a class="text-sm font-bold text-date hover:text-ink" href="/buku">Lihat katalog</a>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {
          relatedBooks.length > 0 ? (
            relatedBooks.map((related) => (
              <article class="soft-card overflow-hidden">
                <img class="aspect-[4/3] w-full bg-parchment object-cover" src={related.data.coverImage} alt={`Sampul ${related.data.title}`} loading="lazy" />
                <div class="p-5">
                  <p class="text-xs font-bold uppercase tracking-[0.14em] text-date">Usia {related.data.ageMin}-{related.data.ageMax}</p>
                  <h3 class="mt-2 font-serif text-xl font-bold leading-tight text-ink">{related.data.title}</h3>
                  <p class="mt-3 text-sm text-[#70675e]">{related.data.shortDescription}</p>
                  <a class="mt-5 inline-flex rounded-full border border-date/25 bg-white/72 px-4 py-2 text-sm font-bold text-ink transition hover:-translate-y-0.5 hover:bg-parchment" href={`/buku/${related.data.slug}`}>
                    Lihat detail
                  </a>
                </div>
              </article>
            ))
          ) : (
            <p class="soft-card p-6 text-sm text-[#70675e] md:col-span-3">
              Belum ada buku terkait yang cocok dari kategori atau tema yang sama.
            </p>
          )
        }
      </div>
    </section>
  </section>
</BaseLayout>

<script>
  import { addToCart, type CartItemInput } from '@/lib/cart';

  const cartButton = document.querySelector<HTMLButtonElement>('[data-cart-button]');

  const getCartItemFromButton = (button: HTMLButtonElement): CartItemInput | null => {
    const { bookSlug, bookTitle, bookPrice, bookCoverImage, bookStockType } = button.dataset;
    const price = Number(bookPrice);

    if (
      !bookSlug ||
      !bookTitle ||
      !bookCoverImage ||
      (bookStockType !== 'preorder' && bookStockType !== 'ready_stock') ||
      !Number.isFinite(price)
    ) {
      return null;
    }

    return {
      slug: bookSlug,
      title: bookTitle,
      price,
      coverImage: bookCoverImage,
      stockType: bookStockType
    };
  };

  cartButton?.addEventListener('click', () => {
    const cartItem = getCartItemFromButton(cartButton);

    if (!cartItem) {
      return;
    }

    addToCart(cartItem);
    cartButton.textContent = 'Masuk Keranjang';
    window.setTimeout(() => {
      cartButton.textContent = 'Masukkan Keranjang';
    }, 1400);
  });
</script>
