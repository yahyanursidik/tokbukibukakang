---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Checkout"
  description="Checkout manual Books by Ibunya Kakang untuk membuat pesanan dan menerima instruksi transfer bank."
>
  <section class="page-shell py-10 sm:py-14">
    <div class="watercolor-panel p-6 sm:p-8 lg:p-10">
      <div class="grid gap-7 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <p class="mb-4 inline-flex rounded-full border border-date/20 bg-white/60 px-4 py-2 text-xs font-bold uppercase tracking-[0.14em] text-date">
            Checkout manual
          </p>
          <h1 class="max-w-3xl font-serif text-4xl font-bold leading-tight text-ink sm:text-5xl">
            Lengkapi data penerima, lalu lanjutkan ke instruksi transfer.
          </h1>
          <p class="mt-5 max-w-2xl text-base text-[#5f564e] sm:text-lg">
            Pesanan dibuat dari isi keranjang di browser ini. Pembayaran tetap manual melalui transfer bank, tanpa payment gateway dan tanpa login.
          </p>
        </div>
        <div class="checkout-motif" aria-hidden="true">
          <span class="checkout-motif-paper"></span>
          <span class="checkout-motif-bookmark"></span>
          <span class="checkout-motif-package"></span>
        </div>
      </div>
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,1fr)_360px]">
      <form class="soft-card grid gap-5 p-5 sm:p-7" data-checkout-form novalidate>
        <div>
          <h2 class="font-serif text-2xl font-bold text-ink">Data pemesan</h2>
          <p class="mt-2 text-sm text-[#70675e]">
            Isi seperlunya untuk pengiriman dan komunikasi invoice. Data sensitif seperti kartu identitas tidak diperlukan.
          </p>
        </div>

        <div class="form-alert hidden border" role="status" aria-live="polite" data-checkout-alert></div>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="checkout-field sm:col-span-2">
            <span>Nama pelanggan</span>
            <input name="customerName" autocomplete="name" required type="text" placeholder="Nama lengkap" />
          </label>

          <label class="checkout-field">
            <span>Nomor WhatsApp</span>
            <input name="whatsappNumber" autocomplete="tel" required type="tel" inputmode="tel" placeholder="08xxxxxxxxxx" />
          </label>

          <label class="checkout-field">
            <span>Email <small>opsional</small></span>
            <input name="email" autocomplete="email" type="email" placeholder="nama@email.com" />
          </label>

          <label class="checkout-field sm:col-span-2">
            <span>Alamat lengkap</span>
            <textarea name="fullAddress" autocomplete="street-address" required rows="4" placeholder="Nama jalan, nomor rumah, RT/RW, kecamatan"></textarea>
          </label>

          <label class="checkout-field">
            <span>Kota/Kabupaten</span>
            <input name="city" autocomplete="address-level2" required type="text" placeholder="Bandung" />
          </label>

          <label class="checkout-field">
            <span>Provinsi</span>
            <input name="province" autocomplete="address-level1" required type="text" placeholder="Jawa Barat" />
          </label>

          <label class="checkout-field">
            <span>Kode pos <small>opsional</small></span>
            <input name="postalCode" autocomplete="postal-code" type="text" inputmode="numeric" placeholder="40123" />
          </label>

          <label class="checkout-field">
            <span>Catatan pengiriman <small>opsional</small></span>
            <input name="shippingNote" type="text" placeholder="Patokan rumah, jam terima paket" />
          </label>

          <label class="checkout-field sm:col-span-2">
            <span>Catatan pesanan <small>opsional</small></span>
            <textarea name="orderNote" rows="3" placeholder="Misal: mohon info jika ada judul PO yang estimasinya berbeda"></textarea>
          </label>
        </div>

        <div class="flex flex-col gap-3 border-t border-[#eadcc7] pt-5 sm:flex-row sm:items-center sm:justify-between">
          <a class="button-secondary" href="/keranjang">
            Kembali ke keranjang
          </a>
          <button class="button-primary disabled:cursor-not-allowed disabled:opacity-55" type="submit" data-checkout-submit>
            Buat pesanan
          </button>
        </div>
      </form>

      <aside class="soft-card h-fit p-5 lg:sticky lg:top-28">
        <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Ringkasan</p>

        <div class="mt-5 hidden rounded-3xl bg-parchment/70 p-4 text-sm text-[#70675e]" role="status" data-checkout-empty>
          Keranjang masih kosong. Tambahkan buku sebelum checkout.
          <a class="mt-3 inline-flex font-bold text-date hover:text-ink" href="/buku">Lihat katalog</a>
        </div>

        <div class="mt-5 grid gap-4" data-checkout-filled>
          <div class="grid gap-3" data-checkout-items></div>

          <dl class="grid gap-3 border-t border-[#eadcc7] pt-4 text-sm">
            <div class="flex items-center justify-between gap-4">
              <dt class="text-[#70675e]">Total item</dt>
              <dd class="font-bold text-ink"><span data-checkout-total-items>0</span></dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-[#70675e]">Ongkir</dt>
              <dd class="font-bold text-ink">Dikonfirmasi Ibu Kakang</dd>
            </div>
            <div class="flex items-center justify-between gap-4 border-t border-[#eadcc7] pt-3">
              <dt class="font-bold text-date">Subtotal</dt>
              <dd class="font-serif text-2xl font-bold text-ink" data-checkout-subtotal>Rp0</dd>
            </div>
          </dl>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<script>
  import {
    CHECKOUT_ORDER_STORAGE_KEY,
    buildOrderNotes,
    buildShippingAddress,
    createManualCheckoutOrder,
    type CheckoutFormValues,
    type StoredCheckoutOrder
  } from '@/lib/checkout';
  import {
    formatRupiah,
    getSubtotal,
    getTotalItems,
    readCart,
    writeCart,
    type CartItem
  } from '@/lib/cart';

  const form = document.querySelector<HTMLFormElement>('[data-checkout-form]');
  const submitButton = document.querySelector<HTMLButtonElement>('[data-checkout-submit]');
  const alertBox = document.querySelector<HTMLElement>('[data-checkout-alert]');
  const emptySummary = document.querySelector<HTMLElement>('[data-checkout-empty]');
  const filledSummary = document.querySelector<HTMLElement>('[data-checkout-filled]');
  const itemsContainer = document.querySelector<HTMLElement>('[data-checkout-items]');
  const totalItemsElement = document.querySelector<HTMLElement>('[data-checkout-total-items]');
  const subtotalElement = document.querySelector<HTMLElement>('[data-checkout-subtotal]');

  const escapeHtml = (value: string) =>
    value
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');

  const setAlert = (message: string, tone: 'error' | 'success' = 'error') => {
    if (!alertBox) {
      return;
    }

    alertBox.textContent = message;
    alertBox.classList.remove('hidden', 'border-date/25', 'bg-parchment/80', 'text-date', 'border-[#b9d8c2]', 'bg-[#edf7ef]', 'text-[#36543c]');

    if (tone === 'success') {
      alertBox.classList.add('border-[#b9d8c2]', 'bg-[#edf7ef]', 'text-[#36543c]');
    } else {
      alertBox.classList.add('border-date/25', 'bg-parchment/80', 'text-date');
    }
  };

  const clearAlert = () => {
    alertBox?.classList.add('hidden');
  };

  const setLoading = (isLoading: boolean) => {
    if (!submitButton) {
      return;
    }

    submitButton.disabled = isLoading || readCart().length === 0;
    submitButton.setAttribute('aria-busy', String(isLoading));
    submitButton.textContent = isLoading ? 'Membuat pesanan...' : 'Buat pesanan';
  };

  const getFormValues = (): CheckoutFormValues => {
    const data = new FormData(form ?? undefined);

    return {
      customerName: String(data.get('customerName') ?? ''),
      whatsappNumber: String(data.get('whatsappNumber') ?? ''),
      email: String(data.get('email') ?? ''),
      fullAddress: String(data.get('fullAddress') ?? ''),
      city: String(data.get('city') ?? ''),
      province: String(data.get('province') ?? ''),
      postalCode: String(data.get('postalCode') ?? ''),
      shippingNote: String(data.get('shippingNote') ?? ''),
      orderNote: String(data.get('orderNote') ?? '')
    };
  };

  const validateCheckout = (values: CheckoutFormValues, items: CartItem[]) => {
    const missingFields = [
      [values.customerName, 'nama pelanggan'],
      [values.whatsappNumber, 'nomor WhatsApp'],
      [values.fullAddress, 'alamat lengkap'],
      [values.city, 'kota/kabupaten'],
      [values.province, 'provinsi']
    ]
      .filter(([value]) => !String(value).trim())
      .map(([, label]) => label);

    if (items.length === 0) {
      return 'Keranjang masih kosong. Tambahkan buku sebelum checkout.';
    }

    if (missingFields.length > 0) {
      return `Mohon lengkapi ${missingFields.join(', ')}.`;
    }

    if (values.whatsappNumber.replace(/\D/g, '').length < 8) {
      return 'Nomor WhatsApp tampaknya belum lengkap.';
    }

    return null;
  };

  const renderSummaryItem = (item: CartItem) => {
    const element = document.createElement('article');
    element.className = 'rounded-3xl border border-[#eadcc7] bg-white/60 p-3';
    element.innerHTML = `
      <div class="flex gap-3">
        <img class="h-16 w-14 rounded-2xl bg-parchment object-cover" src="${escapeHtml(item.coverImage)}" alt="Sampul ${escapeHtml(item.title)}" loading="lazy" />
        <div class="min-w-0 flex-1">
          <h3 class="line-clamp-2 text-sm font-bold leading-snug text-ink">${escapeHtml(item.title)}</h3>
          <p class="mt-1 text-xs font-semibold text-[#70675e]">${item.quantity} x ${formatRupiah(item.price)}</p>
        </div>
      </div>
    `;

    return element;
  };

  const renderCheckout = () => {
    const items = readCart();
    const isEmpty = items.length === 0;

    emptySummary?.classList.toggle('hidden', !isEmpty);
    filledSummary?.classList.toggle('hidden', isEmpty);
    itemsContainer?.replaceChildren(...items.map(renderSummaryItem));

    if (totalItemsElement) {
      totalItemsElement.textContent = String(getTotalItems(items));
    }

    if (subtotalElement) {
      subtotalElement.textContent = formatRupiah(getSubtotal(items));
    }

    if (submitButton) {
      submitButton.disabled = isEmpty;
    }
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    clearAlert();

    const items = readCart();
    const values = getFormValues();
    const validationError = validateCheckout(values, items);

    if (validationError) {
      setAlert(validationError);
      return;
    }

    setLoading(true);

    try {
      const result = await createManualCheckoutOrder(values, items);
      const storedOrder: StoredCheckoutOrder = {
        ...result,
        customerName: values.customerName.trim(),
        whatsappNumber: values.whatsappNumber.trim(),
        email: values.email?.trim() || undefined,
        shippingAddress: buildShippingAddress(values),
        notes: buildOrderNotes(values) || undefined,
        items,
        createdAt: new Date().toISOString()
      };

      window.sessionStorage.setItem(CHECKOUT_ORDER_STORAGE_KEY, JSON.stringify(storedOrder));
      writeCart([]);
      setAlert('Pesanan berhasil dibuat. Mengarahkan ke instruksi pembayaran...', 'success');
      window.location.href = `/checkout/instruksi-pembayaran?invoice=${encodeURIComponent(result.orderNumber)}`;
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Checkout belum berhasil. Silakan coba lagi.';
      setAlert(`Checkout belum berhasil: ${message}`);
      setLoading(false);
    }
  });

  window.addEventListener('storage', (event) => {
    if (event.key === 'ibu-kakang-cart') {
      renderCheckout();
    }
  });

  renderCheckout();
</script>

<style>
  .checkout-field {
    display: grid;
    gap: 0.45rem;
  }

  .checkout-field span {
    color: #5f564e;
    font-size: 0.85rem;
    font-weight: 800;
  }

  .checkout-field small {
    color: #8a5f3f;
    font-size: 0.72rem;
    font-weight: 700;
  }

  .checkout-field input,
  .checkout-field textarea {
    width: 100%;
    border: 1px solid rgba(234, 220, 199, 0.95);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.72);
    color: #2f2a25;
    font: inherit;
    outline: none;
    padding: 0.85rem 1rem;
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease;
  }

  .checkout-field textarea {
    resize: vertical;
  }

  .checkout-field input:focus,
  .checkout-field textarea:focus {
    border-color: rgba(138, 95, 63, 0.55);
    background: rgba(255, 252, 246, 0.96);
    box-shadow: 0 0 0 4px rgba(242, 202, 126, 0.24);
  }

  .checkout-motif {
    height: 170px;
    position: relative;
    width: min(260px, 100%);
  }

  .checkout-motif-paper,
  .checkout-motif-bookmark,
  .checkout-motif-package {
    position: absolute;
  }

  .checkout-motif-paper {
    left: 18px;
    top: 22px;
    height: 108px;
    width: 142px;
    border: 2px solid rgba(138, 95, 63, 0.5);
    border-radius: 24px;
    background:
      repeating-linear-gradient(180deg, transparent 0 18px, rgba(138, 95, 63, 0.12) 18px 20px),
      rgba(255, 250, 241, 0.9);
    transform: rotate(-5deg);
  }

  .checkout-motif-bookmark {
    right: 56px;
    top: 14px;
    height: 104px;
    width: 40px;
    clip-path: polygon(0 0, 100% 0, 100% 100%, 50% 76%, 0 100%);
    background: #eeb7ad;
    border: 2px solid rgba(138, 95, 63, 0.45);
  }

  .checkout-motif-package {
    right: 24px;
    bottom: 16px;
    height: 82px;
    width: 116px;
    border: 2px solid rgba(138, 95, 63, 0.55);
    border-radius: 20px;
    background:
      linear-gradient(90deg, transparent 45%, rgba(138, 95, 63, 0.22) 45% 55%, transparent 55%),
      linear-gradient(180deg, #f2ca7e 0 38%, #f8ecd7 38%);
  }
</style>
