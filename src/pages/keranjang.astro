---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { placeholderPages } from '@/config/site';

const page = placeholderPages.cart;
---

<BaseLayout title="Keranjang" description={page.description}>
  <section class="page-shell py-10 sm:py-14">
    <div class="watercolor-panel p-6 sm:p-8 lg:p-10">
      <div class="grid gap-7 lg:grid-cols-[1fr_auto] lg:items-end">
        <div>
          <p class="mb-4 inline-flex rounded-full border border-date/20 bg-white/60 px-4 py-2 text-xs font-bold uppercase tracking-[0.14em] text-date">
            Keranjang
          </p>
          <h1 class="max-w-3xl font-serif text-4xl font-bold leading-tight text-ink sm:text-5xl">
            Simpan pilihan buku sebelum checkout manual.
          </h1>
          <p class="mt-5 max-w-2xl text-base text-[#5f564e] sm:text-lg">
            Keranjang tersimpan di browser ini. Tidak perlu login, dan isi keranjang hanya dikosongkan setelah pesanan berhasil dibuat.
          </p>
        </div>
        <div class="cart-motif" aria-hidden="true">
          <span class="cart-motif-package"></span>
          <span class="cart-motif-book"></span>
          <span class="cart-motif-paper"></span>
        </div>
      </div>
    </div>

    <section class="mt-8">
      <div class="empty-state hidden" data-cart-empty>
        <div class="motif motif-package mx-auto mb-5 scale-75" aria-hidden="true"></div>
        <h2 class="font-serif text-3xl font-bold text-ink">Keranjang masih kosong.</h2>
        <p class="mx-auto mt-3 max-w-md text-sm text-[#70675e]">
          Pilih buku dari katalog atau halaman PO, lalu kembali ke sini untuk mengatur jumlahnya.
        </p>
        <a class="button-primary mt-6" href="/buku">
          Lanjut belanja
        </a>
      </div>

      <div class="hidden grid gap-6 lg:grid-cols-[1fr_340px]" data-cart-filled>
        <div class="grid gap-4" data-cart-items></div>

        <aside class="soft-card h-fit p-5 lg:sticky lg:top-28">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Ringkasan</p>
          <dl class="mt-5 grid gap-3 text-sm">
            <div class="flex items-center justify-between gap-4">
              <dt class="text-[#70675e]">Total item</dt>
              <dd class="font-bold text-ink"><span data-cart-total-items>0</span></dd>
            </div>
            <div class="flex items-center justify-between gap-4 border-t border-[#eadcc7] pt-3">
              <dt class="font-bold text-date">Subtotal</dt>
              <dd class="font-serif text-2xl font-bold text-ink" data-cart-subtotal>Rp0</dd>
            </div>
          </dl>
          <p class="mt-4 rounded-2xl bg-parchment/70 p-4 text-xs font-medium text-[#70675e]">
            Ongkir dan invoice final akan dikonfirmasi Ibu Kakang pada alur checkout manual.
          </p>
          <div class="mt-5 grid gap-2">
            <a class="button-primary" href="/checkout">
              Lanjut ke checkout
            </a>
            <a class="button-secondary" href="/buku">
              Lanjut belanja
            </a>
          </div>
        </aside>
      </div>
    </section>
  </section>
</BaseLayout>

<script>
  import {
    formatRupiah,
    getSubtotal,
    getTotalItems,
    readCart,
    removeCartItem,
    updateCartItemQuantity,
    type CartItem
  } from '@/lib/cart';

  const emptyState = document.querySelector<HTMLElement>('[data-cart-empty]');
  const filledState = document.querySelector<HTMLElement>('[data-cart-filled]');
  const itemsContainer = document.querySelector<HTMLElement>('[data-cart-items]');
  const totalItemsElement = document.querySelector<HTMLElement>('[data-cart-total-items]');
  const subtotalElement = document.querySelector<HTMLElement>('[data-cart-subtotal]');

  const escapeHtml = (value: string) =>
    value
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');

  const renderCartItem = (item: CartItem) => {
    const article = document.createElement('article');
    article.className = 'soft-card overflow-hidden p-4 sm:p-5';
    article.dataset.cartItem = item.slug;
    article.innerHTML = `
      <div class="grid gap-4 sm:grid-cols-[140px_1fr]">
        <a class="block overflow-hidden rounded-3xl bg-parchment" href="/buku/${encodeURIComponent(item.slug)}">
          <img class="aspect-[4/3] h-full w-full object-cover" src="${escapeHtml(item.coverImage)}" alt="Sampul ${escapeHtml(item.title)}" loading="lazy" />
        </a>
        <div class="grid gap-4">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <span class="inline-flex rounded-full ${item.stockType === 'preorder' ? 'bg-honey text-date' : 'bg-mint text-[#36543c]'} px-3 py-1 text-xs font-bold">
                ${item.stockType === 'preorder' ? 'Pre-order' : 'Ready stock'}
              </span>
              <h2 class="mt-3 font-serif text-xl font-bold leading-tight text-ink">
                <a class="hover:text-date" href="/buku/${encodeURIComponent(item.slug)}">${escapeHtml(item.title)}</a>
              </h2>
              <p class="mt-2 text-sm font-bold text-date">${formatRupiah(item.price)}</p>
            </div>
            <button class="rounded-full border border-date/20 bg-white/70 px-4 py-2 text-sm font-bold text-date hover:bg-parchment" type="button" data-cart-action="remove" data-slug="${escapeHtml(item.slug)}">
              Hapus
            </button>
          </div>
          <div class="flex flex-wrap items-center justify-between gap-4 border-t border-[#eadcc7] pt-4">
            <div class="inline-flex items-center rounded-full border border-date/20 bg-white/70 p-1">
              <button class="grid h-9 w-9 place-items-center rounded-full text-lg font-bold text-date hover:bg-parchment" type="button" data-cart-action="decrease" data-slug="${escapeHtml(item.slug)}" aria-label="Kurangi ${escapeHtml(item.title)}">-</button>
              <input class="h-9 w-14 bg-transparent text-center text-sm font-bold text-ink outline-none" type="number" min="1" max="99" value="${item.quantity}" data-cart-quantity data-slug="${escapeHtml(item.slug)}" aria-label="Jumlah ${escapeHtml(item.title)}" />
              <button class="grid h-9 w-9 place-items-center rounded-full text-lg font-bold text-date hover:bg-parchment" type="button" data-cart-action="increase" data-slug="${escapeHtml(item.slug)}" aria-label="Tambah ${escapeHtml(item.title)}">+</button>
            </div>
            <p class="font-serif text-xl font-bold text-ink">${formatRupiah(item.price * item.quantity)}</p>
          </div>
        </div>
      </div>
    `;

    return article;
  };

  const renderCart = () => {
    if (!emptyState || !filledState || !itemsContainer || !totalItemsElement || !subtotalElement) {
      return;
    }

    const cartItems = readCart();
    const isEmpty = cartItems.length === 0;

    emptyState.classList.toggle('hidden', !isEmpty);
    filledState.classList.toggle('hidden', isEmpty);

    itemsContainer.replaceChildren(...cartItems.map(renderCartItem));
    totalItemsElement.textContent = String(getTotalItems(cartItems));
    subtotalElement.textContent = formatRupiah(getSubtotal(cartItems));
  };

  itemsContainer?.addEventListener('click', (event) => {
    const button = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-cart-action]');

    if (!button) {
      return;
    }

    const slug = button.dataset.slug;
    const cartItems = readCart();
    const item = cartItems.find((cartItem) => cartItem.slug === slug);

    if (!slug || !item) {
      return;
    }

    if (button.dataset.cartAction === 'remove') {
      removeCartItem(slug);
    }

    if (button.dataset.cartAction === 'decrease') {
      updateCartItemQuantity(slug, Math.max(1, item.quantity - 1));
    }

    if (button.dataset.cartAction === 'increase') {
      updateCartItemQuantity(slug, item.quantity + 1);
    }

    renderCart();
  });

  itemsContainer?.addEventListener('change', (event) => {
    const input = (event.target as HTMLElement).closest<HTMLInputElement>('[data-cart-quantity]');

    if (!input || !input.dataset.slug) {
      return;
    }

    updateCartItemQuantity(input.dataset.slug, Number(input.value));
    renderCart();
  });

  renderCart();
</script>

<style>
  .cart-motif {
    height: 170px;
    position: relative;
    width: min(260px, 100%);
  }

  .cart-motif-package,
  .cart-motif-book,
  .cart-motif-paper {
    position: absolute;
  }

  .cart-motif-package {
    bottom: 14px;
    left: 22px;
    height: 94px;
    width: 132px;
    border: 2px solid rgba(138, 95, 63, 0.55);
    border-radius: 22px;
    background:
      linear-gradient(90deg, transparent 45%, rgba(138, 95, 63, 0.2) 45% 55%, transparent 55%),
      linear-gradient(180deg, #f2ca7e 0 38%, #f8ecd7 38%);
  }

  .cart-motif-book {
    right: 28px;
    bottom: 24px;
    height: 112px;
    width: 68px;
    border: 2px solid rgba(138, 95, 63, 0.55);
    border-radius: 14px 8px 8px 14px;
    background: #b8dce8;
    box-shadow: -44px 10px 0 #eeb7ad;
  }

  .cart-motif-paper {
    right: 58px;
    top: 18px;
    height: 70px;
    width: 98px;
    border: 2px solid rgba(138, 95, 63, 0.38);
    border-radius: 18px;
    background: rgba(255, 250, 241, 0.86);
    transform: rotate(7deg);
  }
</style>
