---
import PlaceholderPage from '@/components/PlaceholderPage.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { placeholderPages } from '@/config/site';
import { getCollection } from 'astro:content';

const page = placeholderPages.shoppingGuide;
const pageMeta = (await getCollection('pages')).find((entry) => entry.data.slug === 'panduan-belanja')?.data;
---

<BaseLayout title={pageMeta?.seoTitle ?? 'Panduan Belanja'} description={pageMeta?.seoDescription ?? page.description}>
  <PlaceholderPage {...page} />
</BaseLayout>
