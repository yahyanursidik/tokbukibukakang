---
import PlaceholderPage from '@/components/PlaceholderPage.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { placeholderPages } from '@/config/site';
import { getCollection } from 'astro:content';

const page = placeholderPages.preorder;
const poPeriods = (await getCollection('poPeriods')).filter((period) => period.data.status === 'open');
const formatDate = new Intl.DateTimeFormat('id-ID', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});
---

<BaseLayout title="PO" description={page.description}>
  <PlaceholderPage {...page} />
  <section class="page-shell mt-4">
    <div class="mb-5">
      <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">PO aktif</p>
      <h2 class="font-serif text-3xl font-bold text-ink">Periode yang sedang dibuka</h2>
    </div>
    <div class="grid gap-4">
      {
        poPeriods.map(({ data }) => (
          <article class="soft-card p-5">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.14em] text-date">Status: {data.status}</p>
                <h3 class="mt-2 font-serif text-2xl font-bold text-ink">{data.title}</h3>
                <p class="mt-3 max-w-3xl text-sm text-[#70675e]">{data.description}</p>
              </div>
              <span class="rounded-full bg-mint/70 px-4 py-2 text-sm font-bold text-[#36543c]">
                {data.bookSlugs.length} buku
              </span>
            </div>
            <dl class="mt-5 grid gap-3 text-sm sm:grid-cols-3">
              <div>
                <dt class="font-bold text-date">Mulai</dt>
                <dd class="text-[#5f564e]">{formatDate.format(data.startDate)}</dd>
              </div>
              <div>
                <dt class="font-bold text-date">Tutup</dt>
                <dd class="text-[#5f564e]">{formatDate.format(data.endDate)}</dd>
              </div>
              <div>
                <dt class="font-bold text-date">Estimasi kirim</dt>
                <dd class="text-[#5f564e]">{formatDate.format(data.estimatedShippingDate)}</dd>
              </div>
            </dl>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
