---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublicPoPeriodBySlug, listPublicBooks } from '@/lib/content/public';
import { formatRupiah, getSavingsPercent, hasDiscountPrice } from '@/lib/pricing';

export const prerender = false;

const period = await getPublicPoPeriodBySlug(Astro.params.slug ?? '');

if (!period) {
  return new Response(null, { status: 404 });
}

const books = await listPublicBooks();
const poBooks = books.filter((book) => period.bookSlugs.includes(book.slug));

const formatDate = new Intl.DateTimeFormat('id-ID', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});

const statusLabels = {
  draft: 'Draft',
  open: 'Open',
  closed: 'Closed',
  archived: 'Archived'
} as const;

const statusClass = {
  draft: 'bg-parchment text-date',
  open: 'bg-mint/75 text-[#36543c]',
  closed: 'bg-honey/65 text-date',
  archived: 'bg-white/70 text-[#5f564e]'
} as const;
---

<BaseLayout title={period.title} description={period.description}>
  <section class="page-shell py-10 sm:py-14">
    <a class="mb-6 inline-flex text-sm font-bold text-date hover:text-ink" href={period.status === 'archived' || period.status === 'closed' ? '/riwayat-po' : '/po'}>
      Kembali ke {period.status === 'archived' || period.status === 'closed' ? 'riwayat PO' : 'PO'}
    </a>

    <article class="watercolor-panel p-6 sm:p-8 lg:p-10">
      <div class="flex flex-wrap items-center gap-3">
        <span class={`rounded-full px-3 py-1 text-xs font-bold ${statusClass[period.status]}`}>
          {statusLabels[period.status]}
        </span>
        <span class="rounded-full bg-white/65 px-3 py-1 text-xs font-bold text-date">
          {poBooks.length} buku
        </span>
      </div>

      <h1 class="mt-5 max-w-4xl font-serif text-4xl font-bold leading-tight text-ink sm:text-5xl">
        {period.title}
      </h1>
      <p class="mt-4 max-w-3xl text-[#5f564e] sm:text-lg">{period.description}</p>

      <dl class="mt-7 grid gap-3 text-sm sm:grid-cols-3">
        <div class="rounded-2xl bg-white/62 p-4">
          <dt class="font-bold text-date">Mulai</dt>
          <dd class="mt-1 text-ink">{formatDate.format(period.startDate)}</dd>
        </div>
        <div class="rounded-2xl bg-white/62 p-4">
          <dt class="font-bold text-date">Tutup PO</dt>
          <dd class="mt-1 text-ink">{formatDate.format(period.endDate)}</dd>
        </div>
        <div class="rounded-2xl bg-white/62 p-4">
          <dt class="font-bold text-date">Estimasi kirim</dt>
          <dd class="mt-1 text-ink">{formatDate.format(period.estimatedShippingDate)}</dd>
        </div>
      </dl>

      {period.notes && (
        <div class="mt-6 rounded-3xl border border-date/15 bg-white/62 p-5">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Catatan PO</p>
          <p class="mt-3 text-sm text-[#5f564e]">{period.notes}</p>
        </div>
      )}
    </article>

    <section class="mt-8">
      <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Buku dalam PO</p>
          <h2 class="font-serif text-3xl font-bold text-ink">Daftar pilihan periode ini</h2>
        </div>
        <a class="text-sm font-bold text-date hover:text-ink" href="/buku">Lihat katalog</a>
      </div>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {
          poBooks.map((book) => (
            <article class="soft-card flex min-h-full flex-col overflow-hidden">
              <a class="relative grid aspect-[3/4] place-items-center bg-parchment/80 p-4" href={`/buku/${book.slug}`}>
                <img class="h-full w-full object-contain transition duration-300 hover:scale-[1.03]" src={book.coverImage} alt={`Sampul ${book.title}`} loading="lazy" />
                <span class={`absolute right-4 top-4 rounded-full px-3 py-1 text-xs font-bold shadow-soft ${book.stockType === 'preorder' ? 'bg-honey text-date' : 'bg-mint text-[#36543c]'}`}>
                  {book.stockType === 'preorder' ? 'Pre-order' : 'Ready stock'}
                </span>
              </a>
              <div class="flex flex-1 flex-col p-5">
                <p class="text-xs font-bold uppercase tracking-[0.14em] text-date">Usia {book.ageMin}-{book.ageMax} tahun</p>
                <h3 class="mt-2 font-serif text-xl font-bold leading-tight text-ink">
                  <a class="hover:text-date" href={`/buku/${book.slug}`}>{book.title}</a>
                </h3>
                <p class="mt-3 text-sm leading-6 text-[#70675e]">{book.shortDescription}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {book.themes.slice(0, 3).map((theme) => (
                    <span class="rounded-full border border-date/15 bg-white/65 px-3 py-1 text-xs font-semibold text-[#5f564e]">{theme}</span>
                  ))}
                </div>
                <div class="mt-auto pt-5">
                  <div class="mb-4 rounded-2xl border border-date/15 bg-white/68 p-4">
                    <p class="text-xs font-bold uppercase tracking-[0.14em] text-date">Harga PO</p>
                    {hasDiscountPrice(book) && (
                      <div class="mt-2 flex flex-wrap items-center gap-2">
                        <span class="text-sm font-semibold text-[#8d8278] line-through">{formatRupiah(book.originalPrice!)}</span>
                        <span class="rounded-full bg-honey/70 px-2.5 py-1 text-[0.68rem] font-bold text-date">Hemat {getSavingsPercent(book)}%</span>
                      </div>
                    )}
                    <p class="mt-1 font-serif text-2xl font-bold text-ink">{formatRupiah(book.price)}</p>
                  </div>
                  <div class="grid gap-2 sm:grid-cols-2">
                    <a class="button-secondary" href={`/buku/${book.slug}`}>
                      Lihat detail buku
                    </a>
                    <button
                      class="button-primary"
                      type="button"
                      data-cart-button
                      data-book-slug={book.slug}
                      data-book-title={book.title}
                      data-book-price={book.price}
                      data-book-cover-image={book.coverImage}
                      data-book-stock-type={book.stockType}
                    >
                      Masukkan Keranjang
                    </button>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </section>
</BaseLayout>

<script>
  import { addToCart, type CartItemInput } from '@/lib/cart';

  const getCartItemFromButton = (button: HTMLButtonElement): CartItemInput | null => {
    const { bookSlug, bookTitle, bookPrice, bookCoverImage, bookStockType } = button.dataset;
    const price = Number(bookPrice);

    if (
      !bookSlug ||
      !bookTitle ||
      !bookCoverImage ||
      (bookStockType !== 'preorder' && bookStockType !== 'ready_stock') ||
      !Number.isFinite(price)
    ) {
      return null;
    }

    return {
      slug: bookSlug,
      title: bookTitle,
      price,
      coverImage: bookCoverImage,
      stockType: bookStockType
    };
  };

  document.querySelectorAll<HTMLButtonElement>('[data-cart-button]').forEach((button) => {
    button.addEventListener('click', () => {
      const cartItem = getCartItemFromButton(button);

      if (!cartItem) {
        return;
      }

      addToCart(cartItem);
      button.textContent = 'Sudah masuk';
      button.setAttribute('aria-live', 'polite');
      window.setTimeout(() => {
        button.textContent = 'Masukkan Keranjang';
      }, 1400);
    });
  });
</script>
