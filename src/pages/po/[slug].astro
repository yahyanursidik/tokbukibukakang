---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const poPeriods = await getCollection('poPeriods');

  return poPeriods
    .filter((period) => period.data.status !== 'draft')
    .map((period) => ({
      params: { slug: period.data.slug },
      props: { period }
    }));
}

const { period } = Astro.props;
const books = await getCollection('books');
const poBooks = books.filter((book) => period.data.bookSlugs.includes(book.data.slug));

const formatDate = new Intl.DateTimeFormat('id-ID', {
  day: 'numeric',
  month: 'long',
  year: 'numeric'
});

const formatPrice = new Intl.NumberFormat('id-ID', {
  style: 'currency',
  currency: 'IDR',
  maximumFractionDigits: 0
});

const statusLabels = {
  draft: 'Draft',
  open: 'Open',
  closed: 'Closed',
  archived: 'Archived'
} as const;

const statusClass = {
  draft: 'bg-parchment text-date',
  open: 'bg-mint/75 text-[#36543c]',
  closed: 'bg-honey/65 text-date',
  archived: 'bg-white/70 text-[#5f564e]'
} as const;
---

<BaseLayout title={period.data.title} description={period.data.description}>
  <section class="page-shell py-10 sm:py-14">
    <a class="mb-6 inline-flex text-sm font-bold text-date hover:text-ink" href={period.data.status === 'archived' || period.data.status === 'closed' ? '/riwayat-po' : '/po'}>
      Kembali ke {period.data.status === 'archived' || period.data.status === 'closed' ? 'riwayat PO' : 'PO'}
    </a>

    <article class="watercolor-panel p-6 sm:p-8 lg:p-10">
      <div class="flex flex-wrap items-center gap-3">
        <span class={`rounded-full px-3 py-1 text-xs font-bold ${statusClass[period.data.status]}`}>
          {statusLabels[period.data.status]}
        </span>
        <span class="rounded-full bg-white/65 px-3 py-1 text-xs font-bold text-date">
          {poBooks.length} buku
        </span>
      </div>

      <h1 class="mt-5 max-w-4xl font-serif text-4xl font-bold leading-tight text-ink sm:text-5xl">
        {period.data.title}
      </h1>
      <p class="mt-4 max-w-3xl text-[#5f564e] sm:text-lg">{period.data.description}</p>

      <dl class="mt-7 grid gap-3 text-sm sm:grid-cols-3">
        <div class="rounded-2xl bg-white/62 p-4">
          <dt class="font-bold text-date">Mulai</dt>
          <dd class="mt-1 text-ink">{formatDate.format(period.data.startDate)}</dd>
        </div>
        <div class="rounded-2xl bg-white/62 p-4">
          <dt class="font-bold text-date">Tutup PO</dt>
          <dd class="mt-1 text-ink">{formatDate.format(period.data.endDate)}</dd>
        </div>
        <div class="rounded-2xl bg-white/62 p-4">
          <dt class="font-bold text-date">Estimasi kirim</dt>
          <dd class="mt-1 text-ink">{formatDate.format(period.data.estimatedShippingDate)}</dd>
        </div>
      </dl>

      {period.data.notes && (
        <div class="mt-6 rounded-3xl border border-date/15 bg-white/62 p-5">
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Catatan PO</p>
          <p class="mt-3 text-sm text-[#5f564e]">{period.data.notes}</p>
        </div>
      )}
    </article>

    <section class="mt-8">
      <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Buku dalam PO</p>
          <h2 class="font-serif text-3xl font-bold text-ink">Daftar pilihan periode ini</h2>
        </div>
        <a class="text-sm font-bold text-date hover:text-ink" href="/buku">Lihat katalog</a>
      </div>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {
          poBooks.map(({ data }) => (
            <article class="soft-card flex min-h-full flex-col overflow-hidden">
              <a class="relative block aspect-[4/3] bg-parchment" href={`/buku/${data.slug}`}>
                <img class="h-full w-full object-cover transition duration-300 hover:scale-[1.03]" src={data.coverImage} alt={`Sampul ${data.title}`} loading="lazy" />
                <span class={`absolute right-4 top-4 rounded-full px-3 py-1 text-xs font-bold shadow-soft ${data.stockType === 'preorder' ? 'bg-honey text-date' : 'bg-mint text-[#36543c]'}`}>
                  {data.stockType === 'preorder' ? 'Pre-order' : 'Ready stock'}
                </span>
              </a>
              <div class="flex flex-1 flex-col p-5">
                <p class="text-xs font-bold uppercase tracking-[0.14em] text-date">Usia {data.ageMin}-{data.ageMax} tahun</p>
                <h3 class="mt-2 font-serif text-xl font-bold leading-tight text-ink">
                  <a class="hover:text-date" href={`/buku/${data.slug}`}>{data.title}</a>
                </h3>
                <p class="mt-3 text-sm text-[#70675e]">{data.shortDescription}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {data.themes.slice(0, 3).map((theme) => (
                    <span class="rounded-full border border-date/15 bg-white/65 px-3 py-1 text-xs font-semibold text-[#5f564e]">{theme}</span>
                  ))}
                </div>
                <div class="mt-auto pt-5">
                  <p class="mb-4 font-serif text-2xl font-bold text-ink">{formatPrice.format(data.price)}</p>
                  <div class="grid gap-2 sm:grid-cols-2">
                    <a class="inline-flex items-center justify-center rounded-full border border-date/25 bg-white/72 px-4 py-3 text-sm font-bold text-ink transition hover:-translate-y-0.5 hover:bg-parchment" href={`/buku/${data.slug}`}>
                      Lihat detail buku
                    </a>
                    <button
                      class="inline-flex items-center justify-center rounded-full bg-ink px-4 py-3 text-sm font-bold text-cream transition hover:-translate-y-0.5 hover:bg-date"
                      type="button"
                      data-cart-button
                      data-book-slug={data.slug}
                      data-book-title={data.title}
                      data-book-price={data.price}
                      data-book-cover-image={data.coverImage}
                      data-book-stock-type={data.stockType}
                    >
                      Masukkan Keranjang
                    </button>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </section>
</BaseLayout>

<script>
  import { addToCart, type CartItemInput } from '@/lib/cart';

  const getCartItemFromButton = (button: HTMLButtonElement): CartItemInput | null => {
    const { bookSlug, bookTitle, bookPrice, bookCoverImage, bookStockType } = button.dataset;
    const price = Number(bookPrice);

    if (
      !bookSlug ||
      !bookTitle ||
      !bookCoverImage ||
      (bookStockType !== 'preorder' && bookStockType !== 'ready_stock') ||
      !Number.isFinite(price)
    ) {
      return null;
    }

    return {
      slug: bookSlug,
      title: bookTitle,
      price,
      coverImage: bookCoverImage,
      stockType: bookStockType
    };
  };

  document.querySelectorAll<HTMLButtonElement>('[data-cart-button]').forEach((button) => {
    button.addEventListener('click', () => {
      const cartItem = getCartItemFromButton(button);

      if (!cartItem) {
        return;
      }

      addToCart(cartItem);
      button.textContent = 'Masuk Keranjang';
      window.setTimeout(() => {
        button.textContent = 'Masukkan Keranjang';
      }, 1400);
    });
  });
</script>
