---
import PlaceholderPage from '@/components/PlaceholderPage.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { placeholderPages } from '@/config/site';
import { listPublicReviews } from '@/lib/content/public';

export const prerender = false;

const page = placeholderPages.reviews;
const reviews = await listPublicReviews();
---

<BaseLayout title="Resensi" description={page.description}>
  <PlaceholderPage {...page} />
  <section class="page-shell mt-4">
    <div class="mb-5">
      <p class="text-sm font-bold uppercase tracking-[0.14em] text-date">Contoh resensi</p>
      <h2 class="font-serif text-3xl font-bold text-ink">Ringkasan dari content collection</h2>
    </div>
    <div class="grid gap-4 lg:grid-cols-3">
      {
        reviews.map((review) => (
          <article class="soft-card p-5">
            <p class="text-xs font-bold uppercase tracking-[0.14em] text-date">
              {review.sourceType === 'original' ? 'Resensi original' : 'Ringkasan eksternal'}
            </p>
            <h3 class="mt-3 font-serif text-xl font-bold leading-tight text-ink">{review.title}</h3>
            <p class="mt-3 text-sm text-[#70675e]">{review.summary}</p>
            {review.reviewerNote && (
              <p class="mt-4 rounded-2xl bg-parchment/70 p-3 text-sm font-medium text-[#5f564e]">
                {review.reviewerNote}
              </p>
            )}
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
